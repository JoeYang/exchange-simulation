# KRX E2E: Dynamic price band and VI behaviour
# Tests:
#   Dynamic price bands and VI triggering require set_reference_price()
#   and set_prior_close_price() via the simulator API, which are not
#   exposed as journal actions. Full band/VI testing is covered in
#   krx_exchange_test.cc and krx_integration_test.cc.
#
#   This journal tests the basic order flow scenario: orders within
#   normal price range are accepted; the book maintains correct
#   bid/ask after multiple operations including cancels.
#
# Product: KS (KOSPI200 Futures, tick=500)

ACTION SESSION_START ts=0 state=CONTINUOUS

# Establish a two-sided market
ACTION KRX_FIX_NEW_ORDER ts=1000 instrument=KS cl_ord_id=1 account=1 side=BUY price=3500000 qty=10000 type=LIMIT tif=DAY
EXPECT KRX_EXEC_NEW cl_ord_id=1
EXPECT KRX_MD_QUOTE bid_price=3500000

ACTION KRX_FIX_NEW_ORDER ts=2000 instrument=KS cl_ord_id=2 account=2 side=SELL price=3520000 qty=10000 type=LIMIT tif=DAY
EXPECT KRX_EXEC_NEW cl_ord_id=2
EXPECT KRX_MD_QUOTE ask_price=3520000

# Tighten the spread: new buy above existing bid
ACTION KRX_FIX_NEW_ORDER ts=3000 instrument=KS cl_ord_id=3 account=3 side=BUY price=3510000 qty=10000 type=LIMIT tif=DAY
EXPECT KRX_EXEC_NEW cl_ord_id=3
EXPECT KRX_MD_QUOTE bid_price=3510000

# Tighten the spread: new sell below existing ask
ACTION KRX_FIX_NEW_ORDER ts=4000 instrument=KS cl_ord_id=4 account=4 side=SELL price=3515000 qty=10000 type=LIMIT tif=DAY
EXPECT KRX_EXEC_NEW cl_ord_id=4
EXPECT KRX_MD_QUOTE ask_price=3515000

# Cancel the inner bid — BBO should revert to outer bid
ACTION KRX_FIX_CANCEL ts=5000 instrument=KS cl_ord_id=10 orig_cl_ord_id=3
EXPECT KRX_EXEC_CANCELLED

# Cancel the inner ask — BBO should revert to outer ask
ACTION KRX_FIX_CANCEL ts=6000 instrument=KS cl_ord_id=11 orig_cl_ord_id=4
EXPECT KRX_EXEC_CANCELLED

# Fill at the remaining BBO
ACTION KRX_FIX_NEW_ORDER ts=7000 instrument=KS cl_ord_id=5 account=5 side=SELL price=3500000 qty=10000 type=LIMIT tif=DAY
EXPECT KRX_EXEC_NEW cl_ord_id=5
EXPECT KRX_MD_TRADE price=3500000
