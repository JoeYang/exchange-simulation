# KRX E2E: Calendar spread implied fill lifecycle
# Tests: spread order entry -> outright leg fills -> implied spread fill
#
# Product: KS-CAL (KOSPI200 Calendar Spread, id=3001)
# Legs: KS front (id=1, buy) + KS back (id=1, sell)
# Spread tick: 500 (0.05 index pts)
# Lot size: 10000 (1 contract)

ACTION SESSION_START ts=0 state=CONTINUOUS

# Seed outright books with resting liquidity on both legs.
# KS front: sell 2 contracts at 350.10 (3501000)
ACTION KRX_FIX_NEW_ORDER ts=1000 instrument=KS cl_ord_id=10 account=1 side=SELL price=3501000 qty=20000 type=LIMIT tif=DAY
EXPECT KRX_EXEC_NEW cl_ord_id=10

# KS back: buy 2 contracts at 349.55 (3495500)
ACTION KRX_FIX_NEW_ORDER ts=2000 instrument=KS cl_ord_id=11 account=2 side=BUY price=3495500 qty=20000 type=LIMIT tif=DAY
EXPECT KRX_EXEC_NEW cl_ord_id=11

# Place a calendar spread order: buy 1 spread at +0.50 (5000 fixed-point)
# Spread = front - back => buying spread = buy front, sell back.
# Implied: buy KS front at 3501000, sell KS back at 3495500
# Spread price achieved = 3501000 - 3495500 = 5500 >= 5000 -> fill
ACTION KRX_SPREAD_NEW_ORDER ts=3000 spread_id=3001 cl_ord_id=20 account=3 side=BUY price=5000 qty=10000 tif=DAY
EXPECT KRX_SPREAD_FILL spread_id=3001 cl_ord_id=20 qty=10000

# Verify outright books consumed 1 contract each.
# KS front sell resting should have 1 contract remaining.
# KS back buy resting should have 1 contract remaining.

# Place another spread order at a tighter price that cannot fill.
# Spread buy at +0.60 (6000) -> need front-back <= 6000
# Current best: 3501000 - 3495500 = 5500. 5500 <= 6000 -> fills again.
ACTION KRX_SPREAD_NEW_ORDER ts=4000 spread_id=3001 cl_ord_id=21 account=3 side=BUY price=6000 qty=10000 tif=DAY
EXPECT KRX_SPREAD_FILL spread_id=3001 cl_ord_id=21 qty=10000

# No more outright liquidity -> next spread order rests.
ACTION KRX_SPREAD_NEW_ORDER ts=5000 spread_id=3001 cl_ord_id=22 account=3 side=BUY price=5000 qty=10000 tif=DAY
EXPECT KRX_SPREAD_NEW cl_ord_id=22

# Cancel resting spread order.
ACTION KRX_SPREAD_CANCEL ts=6000 spread_id=3001 order_id=22
EXPECT KRX_SPREAD_CANCELLED order_id=22
