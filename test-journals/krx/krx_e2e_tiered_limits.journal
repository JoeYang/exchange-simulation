# KRX E2E: Tiered daily price limits (basic order flow)
# Tiered limit widening (8% -> 15% -> 20%) is tested at the
# engine integration level (krx_integration_test.cc) since it requires
# setting reference prices via simulator API.
#
# This journal verifies normal order flow with the KTB product which has
# a different tick size (100 = 0.01 pts) than KOSPI200.
#
# Product: KTB (KTB 3-Year Futures)

ACTION SESSION_START ts=0 state=CONTINUOUS

# Buy limit at 110.0000 (1100000 fixed-point)
ACTION KRX_FIX_NEW_ORDER ts=1000 instrument=KTB cl_ord_id=1 account=1 side=BUY price=1100000 qty=10000 type=LIMIT tif=DAY
EXPECT KRX_EXEC_NEW cl_ord_id=1
EXPECT KRX_MD_QUOTE bid_price=1100000

# Sell limit at 110.0100 (1100100 fixed-point) — rests above bid
ACTION KRX_FIX_NEW_ORDER ts=2000 instrument=KTB cl_ord_id=2 account=2 side=SELL price=1100100 qty=10000 type=LIMIT tif=DAY
EXPECT KRX_EXEC_NEW cl_ord_id=2
EXPECT KRX_MD_QUOTE ask_price=1100100

# Sell at best bid — crosses and fills
ACTION KRX_FIX_NEW_ORDER ts=3000 instrument=KTB cl_ord_id=3 account=3 side=SELL price=1100000 qty=10000 type=LIMIT tif=DAY
EXPECT KRX_EXEC_NEW cl_ord_id=3
EXPECT KRX_MD_TRADE price=1100000

# Cancel the resting sell
ACTION KRX_FIX_CANCEL ts=4000 instrument=KTB cl_ord_id=4 orig_cl_ord_id=2
EXPECT KRX_EXEC_CANCELLED
