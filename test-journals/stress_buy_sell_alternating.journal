# stress_buy_sell_alternating.journal
# 100 sell limit orders at 100 distinct price levels, then
# 100 buy limit orders that each cross the best ask, producing
# 100 immediate fills. Tests sustained fill throughput.
CONFIG match_algo=FIFO tick_size=100 lot_size=10000 max_orders=1000 max_levels=100 max_order_ids=10000 price_band_low=0 price_band_high=0

ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=1 side=SELL price=1010000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=1000 cl_ord_id=1 ord_id=1
EXPECT ORDER_BOOK_ACTION ts=1000 action=ADD qty=10000 price=1010000 side=SELL ord_id=1
EXPECT DEPTH_UPDATE ts=1000 action=ADD count=1 qty=10000 price=1010000 side=SELL
EXPECT TOP_OF_BOOK ts=1000 ask_qty=10000 ask=1010000 bid_qty=0 bid=0

ACTION NEW_ORDER ts=2000 cl_ord_id=2 account_id=1 side=SELL price=1010100 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=2000 cl_ord_id=2 ord_id=2
EXPECT ORDER_BOOK_ACTION ts=2000 action=ADD qty=10000 price=1010100 side=SELL ord_id=2
EXPECT DEPTH_UPDATE ts=2000 action=ADD count=1 qty=10000 price=1010100 side=SELL
EXPECT TOP_OF_BOOK ts=2000 ask_qty=10000 ask=1010000 bid_qty=0 bid=0

