# modify_triggers_fill.journal
# A resting buy order is modified (cancel-replace) to a more aggressive price
# that crosses the spread and immediately triggers a fill against a resting
# sell order.
#
# Setup:
#   o1 (sell 10000) rests at 1006000 (ask)
#   o2 (buy  10000) rests at 1004000 (below ask, no match)
#
# Modify o2's price from 1004000 to 1006000.
# The cancel-replace removes o2 at 1004000 and re-enters it at 1006000,
# which crosses the resting sell at 1006000, producing a full fill.
#
# Event ordering (test runner: all order events, then all md events):
# Order events:
#   ORDER_MODIFIED(o2, new_price=1006000)
#   ORDER_FILLED(aggressor=o2, resting=o1)
# MD events:
#   OBA(CANCEL o2 at 1004000), DU(REMOVE at 1004000),
#   TRADE(1006000), OBA(FILL o1 at 1006000), DU(REMOVE ask at 1006000),
#   TOP_OF_BOOK(bid=0, ask=0)

CONFIG match_algo=FIFO tick_size=100 lot_size=10000

# --- action 0: place resting sell at 1006000 ---
ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=1 side=SELL price=1006000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ord_id=1 cl_ord_id=1 ts=1000
EXPECT ORDER_BOOK_ACTION ord_id=1 side=SELL price=1006000 qty=10000 action=ADD ts=1000
EXPECT DEPTH_UPDATE side=SELL price=1006000 qty=10000 count=1 action=ADD ts=1000
EXPECT TOP_OF_BOOK bid=0 bid_qty=0 ask=1006000 ask_qty=10000 ts=1000

# --- action 1: place resting buy at 1004000 (does not cross) ---
ACTION NEW_ORDER ts=2000 cl_ord_id=2 account_id=2 side=BUY price=1004000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ord_id=2 cl_ord_id=2 ts=2000
EXPECT ORDER_BOOK_ACTION ord_id=2 side=BUY price=1004000 qty=10000 action=ADD ts=2000
EXPECT DEPTH_UPDATE side=BUY price=1004000 qty=10000 count=1 action=ADD ts=2000
EXPECT TOP_OF_BOOK bid=1004000 bid_qty=10000 ask=1006000 ask_qty=10000 ts=2000

# --- action 2: modify buy price to 1006000, crossing the spread ---
ACTION MODIFY ts=3000 ord_id=2 cl_ord_id=3 new_price=1006000 new_qty=10000
EXPECT ORDER_MODIFIED ord_id=2 cl_ord_id=3 new_price=1006000 new_qty=10000 ts=3000
EXPECT ORDER_FILLED aggressor=2 resting=1 price=1006000 qty=10000 ts=3000
EXPECT ORDER_BOOK_ACTION ord_id=2 side=BUY price=1004000 qty=10000 action=CANCEL ts=3000
EXPECT DEPTH_UPDATE side=BUY price=1004000 qty=0 count=0 action=REMOVE ts=3000
EXPECT TRADE price=1006000 qty=10000 aggressor=2 resting=1 aggressor_side=BUY ts=3000
EXPECT ORDER_BOOK_ACTION ord_id=1 side=SELL price=1006000 qty=10000 action=FILL ts=3000
EXPECT DEPTH_UPDATE side=SELL price=1006000 qty=0 count=0 action=REMOVE ts=3000
EXPECT TOP_OF_BOOK bid=0 bid_qty=0 ask=0 ask_qty=0 ts=3000
