# modify_triggers_stop.journal
# Resting sell at 1006000. Buy stop at stop_price=1006000.
# Buy at 1004000 (below ask, no fill).
# Modify buy to 1006000 -> crosses sell -> fill -> triggers stop.
# Stop becomes market buy, no liquidity -> IOC_REMAINDER cancel.
CONFIG match_algo=FIFO tick_size=100 lot_size=10000 max_orders=1000 max_levels=100 max_order_ids=10000 price_band_low=0 price_band_high=0

ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=1 side=SELL price=1006000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=1000 cl_ord_id=1 ord_id=1
EXPECT ORDER_BOOK_ACTION ts=1000 action=ADD qty=10000 price=1006000 side=SELL ord_id=1
EXPECT DEPTH_UPDATE ts=1000 action=ADD count=1 qty=10000 price=1006000 side=SELL
EXPECT TOP_OF_BOOK ts=1000 ask_qty=10000 ask=1006000 bid_qty=0 bid=0

ACTION NEW_ORDER ts=2000 cl_ord_id=2 account_id=2 side=BUY price=0 qty=10000 type=STOP tif=GTC stop_price=1006000
EXPECT ORDER_ACCEPTED ts=2000 cl_ord_id=2 ord_id=2

ACTION NEW_ORDER ts=3000 cl_ord_id=3 account_id=3 side=BUY price=1004000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=3000 cl_ord_id=3 ord_id=3
EXPECT ORDER_BOOK_ACTION ts=3000 action=ADD qty=10000 price=1004000 side=BUY ord_id=3
EXPECT DEPTH_UPDATE ts=3000 action=ADD count=1 qty=10000 price=1004000 side=BUY
EXPECT TOP_OF_BOOK ts=3000 ask_qty=10000 ask=1006000 bid_qty=10000 bid=1004000

ACTION MODIFY ts=4000 ord_id=3 cl_ord_id=4 new_price=1006000 new_qty=10000
EXPECT ORDER_MODIFIED new_qty=10000 ts=4000 new_price=1006000 cl_ord_id=4 ord_id=3
EXPECT ORDER_FILLED ts=4000 qty=10000 price=1006000 resting=1 aggressor=3
EXPECT ORDER_CANCELLED reason=IOC_REMAINDER ts=4000 ord_id=2
EXPECT ORDER_BOOK_ACTION ts=4000 action=CANCEL qty=10000 price=1004000 side=BUY ord_id=3
EXPECT DEPTH_UPDATE ts=4000 action=REMOVE count=0 qty=0 price=1004000 side=BUY
EXPECT TRADE ts=4000 aggressor_side=BUY resting=1 aggressor=3 qty=10000 price=1006000
EXPECT ORDER_BOOK_ACTION ts=4000 action=FILL qty=10000 price=1006000 side=SELL ord_id=1
EXPECT DEPTH_UPDATE ts=4000 action=REMOVE count=0 qty=0 price=1006000 side=SELL
EXPECT TOP_OF_BOOK ts=4000 ask_qty=0 ask=0 bid_qty=0 bid=0
