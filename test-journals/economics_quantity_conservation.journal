# economics_quantity_conservation.journal
# Verify quantity conservation: what fills on aggressor = resting.
# Subtest 1: Buy 10 + Sell 10 -> both fully filled
# Subtest 2: Buy 10 + Sell 3 -> partial fill (3 lots)
# Subtest 3: Sell 4 + Sell 3 -> completes the remaining 7 lots
# Total fills on buy order sum to exactly 10 lots.
CONFIG match_algo=FIFO tick_size=100 lot_size=10000 max_orders=1000 max_levels=100 max_order_ids=10000 price_band_low=0 price_band_high=0

ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=1 side=BUY price=1000000 qty=100000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=1000 cl_ord_id=1 ord_id=1
EXPECT ORDER_BOOK_ACTION ts=1000 action=ADD qty=100000 price=1000000 side=BUY ord_id=1
EXPECT DEPTH_UPDATE ts=1000 action=ADD count=1 qty=100000 price=1000000 side=BUY
EXPECT TOP_OF_BOOK ts=1000 ask_qty=0 ask=0 bid_qty=100000 bid=1000000

ACTION NEW_ORDER ts=2000 cl_ord_id=2 account_id=2 side=SELL price=1000000 qty=100000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=2000 cl_ord_id=2 ord_id=2
EXPECT ORDER_FILLED ts=2000 qty=100000 price=1000000 resting=1 aggressor=2
EXPECT TRADE ts=2000 aggressor_side=SELL resting=1 aggressor=2 qty=100000 price=1000000
EXPECT ORDER_BOOK_ACTION ts=2000 action=FILL qty=100000 price=1000000 side=BUY ord_id=1
EXPECT DEPTH_UPDATE ts=2000 action=REMOVE count=0 qty=0 price=1000000 side=BUY
EXPECT TOP_OF_BOOK ts=2000 ask_qty=0 ask=0 bid_qty=0 bid=0

ACTION NEW_ORDER ts=3000 cl_ord_id=3 account_id=3 side=BUY price=1000000 qty=100000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=3000 cl_ord_id=3 ord_id=3
EXPECT ORDER_BOOK_ACTION ts=3000 action=ADD qty=100000 price=1000000 side=BUY ord_id=3
EXPECT DEPTH_UPDATE ts=3000 action=ADD count=1 qty=100000 price=1000000 side=BUY
EXPECT TOP_OF_BOOK ts=3000 ask_qty=0 ask=0 bid_qty=100000 bid=1000000

ACTION NEW_ORDER ts=4000 cl_ord_id=4 account_id=4 side=SELL price=1000000 qty=30000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=4000 cl_ord_id=4 ord_id=4
EXPECT ORDER_FILLED ts=4000 qty=30000 price=1000000 resting=3 aggressor=4
EXPECT TRADE ts=4000 aggressor_side=SELL resting=3 aggressor=4 qty=30000 price=1000000
EXPECT ORDER_BOOK_ACTION ts=4000 action=FILL qty=30000 price=1000000 side=BUY ord_id=3
EXPECT DEPTH_UPDATE ts=4000 action=UPDATE count=1 qty=70000 price=1000000 side=BUY

ACTION NEW_ORDER ts=5000 cl_ord_id=5 account_id=5 side=SELL price=1000000 qty=40000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=5000 cl_ord_id=5 ord_id=5
EXPECT ORDER_FILLED ts=5000 qty=40000 price=1000000 resting=3 aggressor=5
EXPECT TRADE ts=5000 aggressor_side=SELL resting=3 aggressor=5 qty=40000 price=1000000
EXPECT ORDER_BOOK_ACTION ts=5000 action=FILL qty=40000 price=1000000 side=BUY ord_id=3
EXPECT DEPTH_UPDATE ts=5000 action=UPDATE count=1 qty=30000 price=1000000 side=BUY

ACTION NEW_ORDER ts=6000 cl_ord_id=6 account_id=6 side=SELL price=1000000 qty=30000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=6000 cl_ord_id=6 ord_id=6
EXPECT ORDER_FILLED ts=6000 qty=30000 price=1000000 resting=3 aggressor=6
EXPECT TRADE ts=6000 aggressor_side=SELL resting=3 aggressor=6 qty=30000 price=1000000
EXPECT ORDER_BOOK_ACTION ts=6000 action=FILL qty=30000 price=1000000 side=BUY ord_id=3
EXPECT DEPTH_UPDATE ts=6000 action=REMOVE count=0 qty=0 price=1000000 side=BUY
EXPECT TOP_OF_BOOK ts=6000 ask_qty=0 ask=0 bid_qty=0 bid=0
