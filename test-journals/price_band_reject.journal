# Price band rejection: orders outside [price_band_low, price_band_high] are rejected.
# Band: 900000 to 1100000 (90.0000 to 110.0000).
# Order below the band: price=899900 — rejected with PriceBandViolation.
# Order above the band: price=1100100 — rejected with PriceBandViolation.
# Order within the band: price=1005000 — accepted and rests on book.
CONFIG match_algo=FIFO tick_size=100 lot_size=10000 price_band_low=900000 price_band_high=1100000

# Price below band — rejected
ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=1 side=BUY price=899900 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_REJECTED cl_ord_id=1 ts=1000 reason=PRICE_BAND_VIOLATION

# Price above band — rejected
ACTION NEW_ORDER ts=2000 cl_ord_id=2 account_id=1 side=BUY price=1100100 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_REJECTED cl_ord_id=2 ts=2000 reason=PRICE_BAND_VIOLATION

# Price within band — accepted
ACTION NEW_ORDER ts=3000 cl_ord_id=3 account_id=1 side=BUY price=1005000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ord_id=3 cl_ord_id=3 ts=3000
EXPECT ORDER_BOOK_ACTION ord_id=3 side=BUY price=1005000 qty=10000 action=ADD ts=3000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=10000 count=1 action=ADD ts=3000
EXPECT TOP_OF_BOOK bid=1005000 bid_qty=10000 ask=0 ask_qty=0 ts=3000
