# ICE E2E: Place and modify (cancel-replace) order on Cocoa

ACTION SESSION_START ts=0 state=CONTINUOUS

ACTION ICE_FIX_NEW_ORDER ts=1000 instrument=C cl_ord_id=1 account=1 side=BUY price=50000000 qty=10000 type=LIMIT tif=GTC
EXPECT ICE_EXEC_NEW cl_ord_id=1

ACTION ICE_FIX_REPLACE ts=2000 instrument=C cl_ord_id=2 orig_cl_ord_id=1 price=51000000 qty=10000
EXPECT ICE_EXEC_REPLACED cl_ord_id=2
