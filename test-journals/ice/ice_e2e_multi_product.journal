# ICE E2E: Multi-product — Brent + Euribor + Cocoa isolation

ACTION SESSION_START ts=0 state=CONTINUOUS

ACTION ICE_FIX_NEW_ORDER ts=1000 instrument=B cl_ord_id=1 account=1 side=SELL price=800000 qty=10000 type=LIMIT tif=GTC
EXPECT ICE_EXEC_NEW cl_ord_id=1

ACTION ICE_FIX_NEW_ORDER ts=2000 instrument=I cl_ord_id=2 account=2 side=BUY price=960000 qty=10000 type=LIMIT tif=GTC
EXPECT ICE_EXEC_NEW cl_ord_id=2

ACTION ICE_FIX_NEW_ORDER ts=3000 instrument=C cl_ord_id=3 account=3 side=BUY price=50000000 qty=10000 type=LIMIT tif=GTC
EXPECT ICE_EXEC_NEW cl_ord_id=3
