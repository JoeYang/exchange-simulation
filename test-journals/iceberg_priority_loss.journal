# iceberg_priority_loss.journal
# Iceberg sell (total=20000, display=10000) placed first at 1005000.
# Plain sell 10000 placed second at same price.
# Buy 10000 fills iceberg first tranche; iceberg reveals next tranche
# but is moved to back of queue (priority loss).
# Buy another 10000 fills the PLAIN order, not the iceberg's 2nd tranche.
CONFIG match_algo=FIFO tick_size=100 lot_size=10000 max_orders=1000 max_levels=100 max_order_ids=10000 price_band_low=0 price_band_high=0

ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=1 side=SELL price=1005000 qty=20000 type=LIMIT tif=GTC display_qty=10000
EXPECT ORDER_ACCEPTED ts=1000 cl_ord_id=1 ord_id=1
EXPECT ORDER_BOOK_ACTION ts=1000 action=ADD qty=10000 price=1005000 side=SELL ord_id=1
EXPECT DEPTH_UPDATE ts=1000 action=ADD count=1 qty=10000 price=1005000 side=SELL
EXPECT TOP_OF_BOOK ts=1000 ask_qty=10000 ask=1005000 bid_qty=0 bid=0

ACTION NEW_ORDER ts=2000 cl_ord_id=2 account_id=2 side=SELL price=1005000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=2000 cl_ord_id=2 ord_id=2
EXPECT ORDER_BOOK_ACTION ts=2000 action=ADD qty=10000 price=1005000 side=SELL ord_id=2
EXPECT DEPTH_UPDATE ts=2000 action=UPDATE count=2 qty=20000 price=1005000 side=SELL
EXPECT TOP_OF_BOOK ts=2000 ask_qty=20000 ask=1005000 bid_qty=0 bid=0

ACTION NEW_ORDER ts=3000 cl_ord_id=3 account_id=3 side=BUY price=1005000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=3000 cl_ord_id=3 ord_id=3
EXPECT ORDER_FILLED ts=3000 qty=10000 price=1005000 resting=1 aggressor=3
EXPECT TRADE ts=3000 aggressor_side=BUY resting=1 aggressor=3 qty=10000 price=1005000
EXPECT ORDER_BOOK_ACTION ts=3000 action=FILL qty=10000 price=1005000 side=SELL ord_id=1
EXPECT ORDER_BOOK_ACTION ts=3000 action=ADD qty=10000 price=1005000 side=SELL ord_id=1
EXPECT DEPTH_UPDATE ts=3000 action=UPDATE count=2 qty=20000 price=1005000 side=SELL

ACTION NEW_ORDER ts=4000 cl_ord_id=4 account_id=4 side=BUY price=1005000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=4000 cl_ord_id=4 ord_id=4
EXPECT ORDER_FILLED ts=4000 qty=10000 price=1005000 resting=2 aggressor=4
EXPECT TRADE ts=4000 aggressor_side=BUY resting=2 aggressor=4 qty=10000 price=1005000
EXPECT ORDER_BOOK_ACTION ts=4000 action=FILL qty=10000 price=1005000 side=SELL ord_id=2
EXPECT DEPTH_UPDATE ts=4000 action=REMOVE count=0 qty=0 price=1005000 side=SELL
