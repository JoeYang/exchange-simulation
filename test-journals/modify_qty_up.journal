# modify_qty_up.journal
# A resting order's quantity is increased via a modify. Under CancelReplace
# policy this performs a cancel-replace: the old entry is removed and a new
# one is inserted at the same price with the larger quantity. The order
# loses its time priority.
#
# Event ordering (test runner: all order events, then all md events):
# Order events: ORDER_MODIFIED
# MD events:
#   OBA(CANCEL at price),    DU(REMOVE at price),
#   OBA(ADD at same price),  DU(ADD at same price),
#   TOP_OF_BOOK

CONFIG match_algo=FIFO tick_size=100 lot_size=10000

# --- action 0: place a resting buy with 10000 qty ---
ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=1 side=BUY price=1005000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ord_id=1 cl_ord_id=1 ts=1000
EXPECT ORDER_BOOK_ACTION ord_id=1 side=BUY price=1005000 qty=10000 action=ADD ts=1000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=10000 count=1 action=ADD ts=1000
EXPECT TOP_OF_BOOK bid=1005000 bid_qty=10000 ask=0 ask_qty=0 ts=1000

# --- action 1: increase qty from 10000 to 30000 (cancel-replace) ---
ACTION MODIFY ts=2000 ord_id=1 cl_ord_id=2 new_price=1005000 new_qty=30000
EXPECT ORDER_MODIFIED ord_id=1 cl_ord_id=2 new_price=1005000 new_qty=30000 ts=2000
EXPECT ORDER_BOOK_ACTION ord_id=1 side=BUY price=1005000 qty=10000 action=CANCEL ts=2000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=0 count=0 action=REMOVE ts=2000
EXPECT ORDER_BOOK_ACTION ord_id=1 side=BUY price=1005000 qty=30000 action=ADD ts=2000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=30000 count=1 action=ADD ts=2000
EXPECT TOP_OF_BOOK bid=1005000 bid_qty=30000 ask=0 ask_qty=0 ts=2000
