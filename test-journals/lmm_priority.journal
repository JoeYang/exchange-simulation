# LMM priority: 40% market maker allocation, then FIFO for remainder
CONFIG tick_size=100 lot_size=10000 match_algo=FIFO_LMM

# Regular buy rests at 100.0000
ACTION NEW_ORDER cl_ord_id=1 account_id=1 side=BUY type=LIMIT price=1000000 qty=100000 ts=1
EXPECT ORDER_ACCEPTED ord_id=1 cl_ord_id=1 ts=1
EXPECT ORDER_BOOK_ACTION ord_id=1 side=BUY price=1000000 qty=100000 action=ADD ts=1
EXPECT DEPTH_UPDATE side=BUY price=1000000 qty=100000 count=1 action=ADD ts=1
EXPECT TOP_OF_BOOK bid=1000000 bid_qty=100000 ask=0 ask_qty=0 ts=1

# MM buy rests at same price
ACTION NEW_ORDER cl_ord_id=2 account_id=2 side=BUY type=LIMIT price=1000000 qty=100000 is_mm=true ts=2
EXPECT ORDER_ACCEPTED ord_id=2 cl_ord_id=2 ts=2
EXPECT ORDER_BOOK_ACTION ord_id=2 side=BUY price=1000000 qty=100000 action=ADD ts=2
EXPECT DEPTH_UPDATE side=BUY price=1000000 qty=200000 count=2 action=UPDATE ts=2
EXPECT TOP_OF_BOOK bid=1000000 bid_qty=200000 ask=0 ask_qty=0 ts=2

# Aggressor sells 100000 at 100.0000
# MM gets 40% priority (40000), FIFO remainder: regular gets 60000
# Event merge order: all order events first, then all MD events
ACTION NEW_ORDER cl_ord_id=3 account_id=3 side=SELL type=LIMIT price=1000000 qty=100000 ts=3
EXPECT ORDER_ACCEPTED ord_id=3 cl_ord_id=3 ts=3
EXPECT ORDER_FILLED aggressor=3 resting=2 price=1000000 qty=40000 ts=3
EXPECT ORDER_FILLED aggressor=3 resting=1 price=1000000 qty=60000 ts=3
EXPECT TRADE price=1000000 qty=40000 aggressor=3 resting=2 aggressor_side=SELL ts=3
EXPECT ORDER_BOOK_ACTION ord_id=2 side=BUY price=1000000 qty=40000 action=FILL ts=3
EXPECT DEPTH_UPDATE side=BUY price=1000000 qty=160000 count=2 action=UPDATE ts=3
EXPECT TRADE price=1000000 qty=60000 aggressor=3 resting=1 aggressor_side=SELL ts=3
EXPECT ORDER_BOOK_ACTION ord_id=1 side=BUY price=1000000 qty=60000 action=FILL ts=3
EXPECT DEPTH_UPDATE side=BUY price=1000000 qty=100000 count=2 action=UPDATE ts=3
