# auction_no_cross.journal
# Bid at 99.0000, ask at 101.0000 — no crossing.
# execute_auction is a no-op: no fills, no events.
CONFIG match_algo=FIFO tick_size=100 lot_size=10000 max_orders=1000 max_levels=100 max_order_ids=10000 price_band_low=0 price_band_high=0

ACTION SET_SESSION_STATE ts=1000 state=PRE_OPEN
EXPECT MARKET_STATUS ts=1000 state=PRE_OPEN

ACTION NEW_ORDER ts=2000 cl_ord_id=1 account_id=1 side=BUY price=990000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=2000 cl_ord_id=1 ord_id=1
EXPECT ORDER_BOOK_ACTION ts=2000 action=ADD qty=10000 price=990000 side=BUY ord_id=1
EXPECT DEPTH_UPDATE ts=2000 action=ADD count=1 qty=10000 price=990000 side=BUY
EXPECT TOP_OF_BOOK ts=2000 ask_qty=0 ask=0 bid_qty=10000 bid=990000

ACTION NEW_ORDER ts=3000 cl_ord_id=2 account_id=2 side=SELL price=1010000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=3000 cl_ord_id=2 ord_id=2
EXPECT ORDER_BOOK_ACTION ts=3000 action=ADD qty=10000 price=1010000 side=SELL ord_id=2
EXPECT DEPTH_UPDATE ts=3000 action=ADD count=1 qty=10000 price=1010000 side=SELL
EXPECT TOP_OF_BOOK ts=3000 ask_qty=10000 ask=1010000 bid_qty=10000 bid=990000

ACTION EXECUTE_AUCTION ts=5000 reference_price=1000000
