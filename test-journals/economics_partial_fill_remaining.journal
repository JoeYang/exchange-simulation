# economics_partial_fill_remaining.journal
# Verify remaining_quantity tracking through multiple partial fills.
# Buy 100 lots -> Sell 20 -> Sell 30 -> Sell 50.
# Fill quantities: 200000 + 300000 + 500000 = 1000000 (100 lots).
CONFIG match_algo=FIFO tick_size=100 lot_size=10000 max_orders=1000 max_levels=100 max_order_ids=10000 price_band_low=0 price_band_high=0

ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=1 side=BUY price=1000000 qty=1000000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=1000 cl_ord_id=1 ord_id=1
EXPECT ORDER_BOOK_ACTION ts=1000 action=ADD qty=1000000 price=1000000 side=BUY ord_id=1
EXPECT DEPTH_UPDATE ts=1000 action=ADD count=1 qty=1000000 price=1000000 side=BUY
EXPECT TOP_OF_BOOK ts=1000 ask_qty=0 ask=0 bid_qty=1000000 bid=1000000

ACTION NEW_ORDER ts=2000 cl_ord_id=2 account_id=2 side=SELL price=1000000 qty=200000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=2000 cl_ord_id=2 ord_id=2
EXPECT ORDER_FILLED ts=2000 qty=200000 price=1000000 resting=1 aggressor=2
EXPECT TRADE ts=2000 aggressor_side=SELL resting=1 aggressor=2 qty=200000 price=1000000
EXPECT ORDER_BOOK_ACTION ts=2000 action=FILL qty=200000 price=1000000 side=BUY ord_id=1
EXPECT DEPTH_UPDATE ts=2000 action=UPDATE count=1 qty=800000 price=1000000 side=BUY

ACTION NEW_ORDER ts=3000 cl_ord_id=3 account_id=3 side=SELL price=1000000 qty=300000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=3000 cl_ord_id=3 ord_id=3
EXPECT ORDER_FILLED ts=3000 qty=300000 price=1000000 resting=1 aggressor=3
EXPECT TRADE ts=3000 aggressor_side=SELL resting=1 aggressor=3 qty=300000 price=1000000
EXPECT ORDER_BOOK_ACTION ts=3000 action=FILL qty=300000 price=1000000 side=BUY ord_id=1
EXPECT DEPTH_UPDATE ts=3000 action=UPDATE count=1 qty=500000 price=1000000 side=BUY

ACTION NEW_ORDER ts=4000 cl_ord_id=4 account_id=4 side=SELL price=1000000 qty=500000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=4000 cl_ord_id=4 ord_id=4
EXPECT ORDER_FILLED ts=4000 qty=500000 price=1000000 resting=1 aggressor=4
EXPECT TRADE ts=4000 aggressor_side=SELL resting=1 aggressor=4 qty=500000 price=1000000
EXPECT ORDER_BOOK_ACTION ts=4000 action=FILL qty=500000 price=1000000 side=BUY ord_id=1
EXPECT DEPTH_UPDATE ts=4000 action=REMOVE count=0 qty=0 price=1000000 side=BUY
EXPECT TOP_OF_BOOK ts=4000 ask_qty=0 ask=0 bid_qty=0 bid=0
