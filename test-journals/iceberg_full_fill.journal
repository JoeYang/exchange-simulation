# iceberg_full_fill.journal
# Iceberg sell (total=20000, display=10000) at price 1000000.
# A buy of 20000 consumes both tranches entirely.
# Order is removed from book after full consumption.
CONFIG match_algo=FIFO tick_size=100 lot_size=10000 max_orders=1000 max_levels=100 max_order_ids=10000 price_band_low=0 price_band_high=0

ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=1 side=SELL price=1000000 qty=20000 type=LIMIT tif=GTC display_qty=10000
EXPECT ORDER_ACCEPTED ts=1000 cl_ord_id=1 ord_id=1
EXPECT ORDER_BOOK_ACTION ts=1000 action=ADD qty=10000 price=1000000 side=SELL ord_id=1
EXPECT DEPTH_UPDATE ts=1000 action=ADD count=1 qty=10000 price=1000000 side=SELL
EXPECT TOP_OF_BOOK ts=1000 ask_qty=10000 ask=1000000 bid_qty=0 bid=0

ACTION NEW_ORDER ts=2000 cl_ord_id=2 account_id=2 side=BUY price=1000000 qty=20000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=2000 cl_ord_id=2 ord_id=2
EXPECT ORDER_PARTIALLY_FILLED resting_rem=0 ts=2000 aggressor_rem=10000 qty=10000 price=1000000 resting=1 aggressor=2
EXPECT ORDER_FILLED ts=2000 qty=10000 price=1000000 resting=1 aggressor=2
EXPECT TRADE ts=2000 aggressor_side=BUY resting=1 aggressor=2 qty=10000 price=1000000
EXPECT ORDER_BOOK_ACTION ts=2000 action=FILL qty=10000 price=1000000 side=SELL ord_id=1
EXPECT ORDER_BOOK_ACTION ts=2000 action=ADD qty=10000 price=1000000 side=SELL ord_id=1
EXPECT DEPTH_UPDATE ts=2000 action=UPDATE count=1 qty=10000 price=1000000 side=SELL
EXPECT TRADE ts=2000 aggressor_side=BUY resting=1 aggressor=2 qty=10000 price=1000000
EXPECT ORDER_BOOK_ACTION ts=2000 action=FILL qty=10000 price=1000000 side=SELL ord_id=1
EXPECT DEPTH_UPDATE ts=2000 action=REMOVE count=0 qty=0 price=1000000 side=SELL
EXPECT TOP_OF_BOOK ts=2000 ask_qty=0 ask=0 bid_qty=0 bid=0
