# economics_auction_price_volume.journal
# Verify auction equilibrium price maximises volume.
# Bids: 10@101, 20@100.50, 30@100.
# Asks: 15@99.50, 25@100, 10@100.50.
# Auction price = 100.0000, matched volume = 40 lots.
# All fills and trades at the single auction price.
CONFIG match_algo=FIFO tick_size=100 lot_size=10000 max_orders=1000 max_levels=100 max_order_ids=10000 price_band_low=0 price_band_high=0

ACTION SET_SESSION_STATE ts=1000 state=PRE_OPEN
EXPECT MARKET_STATUS ts=1000 state=PRE_OPEN

ACTION NEW_ORDER ts=2000 cl_ord_id=1 account_id=1 side=BUY price=1010000 qty=100000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=2000 cl_ord_id=1 ord_id=1
EXPECT ORDER_BOOK_ACTION ts=2000 action=ADD qty=100000 price=1010000 side=BUY ord_id=1
EXPECT DEPTH_UPDATE ts=2000 action=ADD count=1 qty=100000 price=1010000 side=BUY
EXPECT TOP_OF_BOOK ts=2000 ask_qty=0 ask=0 bid_qty=100000 bid=1010000

ACTION NEW_ORDER ts=3000 cl_ord_id=2 account_id=1 side=BUY price=1005000 qty=200000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=3000 cl_ord_id=2 ord_id=2
EXPECT ORDER_BOOK_ACTION ts=3000 action=ADD qty=200000 price=1005000 side=BUY ord_id=2
EXPECT DEPTH_UPDATE ts=3000 action=ADD count=1 qty=200000 price=1005000 side=BUY
EXPECT TOP_OF_BOOK ts=3000 ask_qty=0 ask=0 bid_qty=100000 bid=1010000

ACTION NEW_ORDER ts=4000 cl_ord_id=3 account_id=1 side=BUY price=1000000 qty=300000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=4000 cl_ord_id=3 ord_id=3
EXPECT ORDER_BOOK_ACTION ts=4000 action=ADD qty=300000 price=1000000 side=BUY ord_id=3
EXPECT DEPTH_UPDATE ts=4000 action=ADD count=1 qty=300000 price=1000000 side=BUY
EXPECT TOP_OF_BOOK ts=4000 ask_qty=0 ask=0 bid_qty=100000 bid=1010000

ACTION NEW_ORDER ts=5000 cl_ord_id=4 account_id=2 side=SELL price=995000 qty=150000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=5000 cl_ord_id=4 ord_id=4
EXPECT ORDER_BOOK_ACTION ts=5000 action=ADD qty=150000 price=995000 side=SELL ord_id=4
EXPECT DEPTH_UPDATE ts=5000 action=ADD count=1 qty=150000 price=995000 side=SELL
EXPECT TOP_OF_BOOK ts=5000 ask_qty=150000 ask=995000 bid_qty=100000 bid=1010000

ACTION NEW_ORDER ts=6000 cl_ord_id=5 account_id=2 side=SELL price=1000000 qty=250000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=6000 cl_ord_id=5 ord_id=5
EXPECT ORDER_BOOK_ACTION ts=6000 action=ADD qty=250000 price=1000000 side=SELL ord_id=5
EXPECT DEPTH_UPDATE ts=6000 action=ADD count=1 qty=250000 price=1000000 side=SELL
EXPECT TOP_OF_BOOK ts=6000 ask_qty=150000 ask=995000 bid_qty=100000 bid=1010000

ACTION NEW_ORDER ts=7000 cl_ord_id=6 account_id=2 side=SELL price=1005000 qty=100000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=7000 cl_ord_id=6 ord_id=6
EXPECT ORDER_BOOK_ACTION ts=7000 action=ADD qty=100000 price=1005000 side=SELL ord_id=6
EXPECT DEPTH_UPDATE ts=7000 action=ADD count=1 qty=100000 price=1005000 side=SELL
EXPECT TOP_OF_BOOK ts=7000 ask_qty=150000 ask=995000 bid_qty=100000 bid=1010000

ACTION PUBLISH_INDICATIVE ts=8000 reference_price=1000000
EXPECT INDICATIVE_PRICE ts=8000 sell_surplus=0 buy_surplus=200000 matched_vol=400000 price=1000000

ACTION EXECUTE_AUCTION ts=9000 reference_price=1000000
EXPECT ORDER_PARTIALLY_FILLED resting_rem=50000 ts=9000 aggressor_rem=0 qty=100000 price=1000000 resting=4 aggressor=1
EXPECT ORDER_PARTIALLY_FILLED resting_rem=0 ts=9000 aggressor_rem=150000 qty=50000 price=1000000 resting=4 aggressor=2
EXPECT ORDER_PARTIALLY_FILLED resting_rem=100000 ts=9000 aggressor_rem=0 qty=150000 price=1000000 resting=5 aggressor=2
EXPECT ORDER_PARTIALLY_FILLED resting_rem=0 ts=9000 aggressor_rem=200000 qty=100000 price=1000000 resting=5 aggressor=3
EXPECT TRADE ts=9000 aggressor_side=BUY resting=4 aggressor=1 qty=100000 price=1000000
EXPECT ORDER_BOOK_ACTION ts=9000 action=FILL qty=100000 price=1000000 side=BUY ord_id=1
EXPECT ORDER_BOOK_ACTION ts=9000 action=FILL qty=100000 price=1000000 side=SELL ord_id=4
EXPECT DEPTH_UPDATE ts=9000 action=REMOVE count=0 qty=0 price=1010000 side=BUY
EXPECT TRADE ts=9000 aggressor_side=BUY resting=4 aggressor=2 qty=50000 price=1000000
EXPECT ORDER_BOOK_ACTION ts=9000 action=FILL qty=50000 price=1000000 side=BUY ord_id=2
EXPECT ORDER_BOOK_ACTION ts=9000 action=FILL qty=50000 price=1000000 side=SELL ord_id=4
EXPECT DEPTH_UPDATE ts=9000 action=REMOVE count=0 qty=0 price=995000 side=SELL
EXPECT TRADE ts=9000 aggressor_side=BUY resting=5 aggressor=2 qty=150000 price=1000000
EXPECT ORDER_BOOK_ACTION ts=9000 action=FILL qty=150000 price=1000000 side=BUY ord_id=2
EXPECT ORDER_BOOK_ACTION ts=9000 action=FILL qty=150000 price=1000000 side=SELL ord_id=5
EXPECT DEPTH_UPDATE ts=9000 action=REMOVE count=0 qty=0 price=1005000 side=BUY
EXPECT TRADE ts=9000 aggressor_side=BUY resting=5 aggressor=3 qty=100000 price=1000000
EXPECT ORDER_BOOK_ACTION ts=9000 action=FILL qty=100000 price=1000000 side=BUY ord_id=3
EXPECT ORDER_BOOK_ACTION ts=9000 action=FILL qty=100000 price=1000000 side=SELL ord_id=5
EXPECT DEPTH_UPDATE ts=9000 action=REMOVE count=0 qty=0 price=1000000 side=SELL
EXPECT TOP_OF_BOOK ts=9000 ask_qty=100000 ask=1005000 bid_qty=200000 bid=1000000
