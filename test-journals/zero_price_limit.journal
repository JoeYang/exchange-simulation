# Zero price limit order rejection: price=0 is invalid for a LIMIT order.
# The engine requires a positive price for limit orders.
# Rejected with reason InvalidPrice. No market data events fire.
CONFIG match_algo=FIFO tick_size=100 lot_size=10000

ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=1 side=BUY price=0 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_REJECTED cl_ord_id=1 ts=1000 reason=INVALID_PRICE
