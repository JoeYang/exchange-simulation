# modify_same_price.journal
# A modify is submitted with the same price as the existing order but a
# different quantity. Under CancelReplace policy this still performs a
# cancel-replace even when the price is unchanged: the order is removed
# from the book and re-inserted, losing its time priority.
#
# To observe the priority loss, a second buy order at the same price is
# placed before the modify. After the modify, the modified order appears
# behind order 2 in the queue.
#
# Event ordering (test runner: all order events, then all md events):
# Order events: ORDER_MODIFIED
# MD events:
#   OBA(CANCEL o1 at 1005000, qty=10000), DU(UPDATE at 1005000 -> qty=10000 count=1),
#   OBA(ADD o1 at 1005000, qty=20000),    DU(UPDATE at 1005000 -> qty=30000 count=2),
#   TOP_OF_BOOK (bid_qty changed)

CONFIG match_algo=FIFO tick_size=100 lot_size=10000

# --- action 0: place first resting buy ---
ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=1 side=BUY price=1005000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ord_id=1 cl_ord_id=1 ts=1000
EXPECT ORDER_BOOK_ACTION ord_id=1 side=BUY price=1005000 qty=10000 action=ADD ts=1000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=10000 count=1 action=ADD ts=1000
EXPECT TOP_OF_BOOK bid=1005000 bid_qty=10000 ask=0 ask_qty=0 ts=1000

# --- action 1: place second resting buy at the same price ---
ACTION NEW_ORDER ts=2000 cl_ord_id=2 account_id=1 side=BUY price=1005000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ord_id=2 cl_ord_id=2 ts=2000
EXPECT ORDER_BOOK_ACTION ord_id=2 side=BUY price=1005000 qty=10000 action=ADD ts=2000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=20000 count=2 action=UPDATE ts=2000
EXPECT TOP_OF_BOOK bid=1005000 bid_qty=20000 ask=0 ask_qty=0 ts=2000

# --- action 2: modify order 1 at same price, qty 10000->20000 (cancel-replace) ---
# o1 is removed from the level, leaving o2 alone (qty=10000, count=1).
# Then o1 is re-inserted at the same price (qty=20000), making level qty=30000, count=2.
ACTION MODIFY ts=3000 ord_id=1 cl_ord_id=3 new_price=1005000 new_qty=20000
EXPECT ORDER_MODIFIED ord_id=1 cl_ord_id=3 new_price=1005000 new_qty=20000 ts=3000
EXPECT ORDER_BOOK_ACTION ord_id=1 side=BUY price=1005000 qty=10000 action=CANCEL ts=3000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=10000 count=1 action=UPDATE ts=3000
EXPECT ORDER_BOOK_ACTION ord_id=1 side=BUY price=1005000 qty=20000 action=ADD ts=3000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=30000 count=2 action=UPDATE ts=3000
EXPECT TOP_OF_BOOK bid=1005000 bid_qty=30000 ask=0 ask_qty=0 ts=3000
