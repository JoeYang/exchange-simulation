# smp_cancel_newest.journal
# CONFIG match_algo=FIFO_SMP (SmpFifoExchange with CancelNewest).
# Resting buy from account 1, then crossing sell from same account.
# SMP fires: sell (aggressor) is accepted then immediately cancelled
# with reason SELF_MATCH_PREVENTION. No trade occurs; buy survives.
CONFIG match_algo=FIFO_SMP tick_size=100 lot_size=10000 max_orders=1000 max_levels=100 max_order_ids=10000 price_band_low=0 price_band_high=0

ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=1 side=BUY price=1000000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=1000 cl_ord_id=1 ord_id=1
EXPECT ORDER_BOOK_ACTION ts=1000 action=ADD qty=10000 price=1000000 side=BUY ord_id=1
EXPECT DEPTH_UPDATE ts=1000 action=ADD count=1 qty=10000 price=1000000 side=BUY
EXPECT TOP_OF_BOOK ts=1000 ask_qty=0 ask=0 bid_qty=10000 bid=1000000

ACTION NEW_ORDER ts=2000 cl_ord_id=2 account_id=1 side=SELL price=1000000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=2000 cl_ord_id=2 ord_id=2
EXPECT ORDER_CANCELLED reason=SELF_MATCH_PREVENTION ts=2000 ord_id=2
