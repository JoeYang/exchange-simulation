# Trade bust: two orders cross, producing a trade, then bust reverses it
# Setup: buy and sell at same price, full fill
CONFIG match_algo=FIFO tick_size=100 lot_size=10000

ACTION NEW_ORDER cl_ord_id=1 side=BUY type=LIMIT price=1000000 qty=50000 ts=1
EXPECT ORDER_ACCEPTED ord_id=1 cl_ord_id=1 ts=1
EXPECT ORDER_BOOK_ACTION ord_id=1 side=BUY price=1000000 qty=50000 action=ADD ts=1
EXPECT DEPTH_UPDATE side=BUY price=1000000 qty=50000 count=1 action=ADD ts=1
EXPECT TOP_OF_BOOK bid=1000000 bid_qty=50000 ask=0 ask_qty=0 ts=1

ACTION NEW_ORDER cl_ord_id=2 side=SELL type=LIMIT price=1000000 qty=50000 ts=2
EXPECT ORDER_ACCEPTED ord_id=2 cl_ord_id=2 ts=2
EXPECT ORDER_FILLED aggressor=2 resting=1 price=1000000 qty=50000 ts=2
EXPECT TRADE price=1000000 qty=50000 aggressor=2 resting=1 aggressor_side=SELL ts=2
EXPECT ORDER_BOOK_ACTION ord_id=1 side=BUY price=1000000 qty=50000 action=FILL ts=2
EXPECT DEPTH_UPDATE side=BUY price=1000000 qty=0 count=0 action=REMOVE ts=2
EXPECT TOP_OF_BOOK bid=0 bid_qty=0 ask=0 ask_qty=0 ts=2

# Bust the trade
ACTION BUST_TRADE trade_id=1 ts=3
EXPECT TRADE_BUSTED trade_id=1 aggressor=2 resting=1 price=1000000 qty=50000 ts=3
