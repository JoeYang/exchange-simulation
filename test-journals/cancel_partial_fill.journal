# cancel_partial_fill.journal
# Buy 30000. Sell 10000 partially fills it (remaining=20000).
# User cancels the remainder.
# Verifies ORDER_CANCELLED fires with the correct remaining qty,
# and that the L3 Cancel and L2 Remove events are correct.
CONFIG match_algo=FIFO tick_size=100 lot_size=10000 max_orders=1000 max_levels=100 max_order_ids=10000 price_band_low=0 price_band_high=0

ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=1 side=BUY price=1005000 qty=30000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=1000 cl_ord_id=1 ord_id=1
EXPECT ORDER_BOOK_ACTION ts=1000 action=ADD qty=30000 price=1005000 side=BUY ord_id=1
EXPECT DEPTH_UPDATE ts=1000 action=ADD count=1 qty=30000 price=1005000 side=BUY
EXPECT TOP_OF_BOOK ts=1000 ask_qty=0 ask=0 bid_qty=30000 bid=1005000

ACTION NEW_ORDER ts=2000 cl_ord_id=2 account_id=2 side=SELL price=1005000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=2000 cl_ord_id=2 ord_id=2
EXPECT ORDER_FILLED ts=2000 qty=10000 price=1005000 resting=1 aggressor=2
EXPECT TRADE ts=2000 aggressor_side=SELL resting=1 aggressor=2 qty=10000 price=1005000
EXPECT ORDER_BOOK_ACTION ts=2000 action=FILL qty=10000 price=1005000 side=BUY ord_id=1
EXPECT DEPTH_UPDATE ts=2000 action=UPDATE count=1 qty=20000 price=1005000 side=BUY

ACTION CANCEL ts=3000 ord_id=1
EXPECT ORDER_CANCELLED reason=USER_REQUESTED ts=3000 ord_id=1
EXPECT ORDER_BOOK_ACTION ts=3000 action=CANCEL qty=20000 price=1005000 side=BUY ord_id=1
EXPECT DEPTH_UPDATE ts=3000 action=REMOVE count=0 qty=0 price=1005000 side=BUY
EXPECT TOP_OF_BOOK ts=3000 ask_qty=0 ask=0 bid_qty=0 bid=0
