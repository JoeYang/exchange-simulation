# session_preopen_market_reject.journal
# In PreOpen, the engine is in collection phase (no matching).
# A market order is accepted and then immediately cancelled with
# IOCRemainder because market orders cannot rest.
CONFIG match_algo=FIFO tick_size=100 lot_size=10000 max_orders=1000 max_levels=100 max_order_ids=10000 price_band_low=0 price_band_high=0

ACTION SET_SESSION_STATE ts=1000 state=PRE_OPEN
EXPECT MARKET_STATUS ts=1000 state=PRE_OPEN

ACTION NEW_ORDER ts=2000 cl_ord_id=1 account_id=1 side=BUY price=0 qty=10000 type=MARKET tif=GTC
EXPECT ORDER_ACCEPTED ts=2000 cl_ord_id=1 ord_id=1
EXPECT ORDER_CANCELLED reason=IOC_REMAINDER ts=2000 ord_id=1
