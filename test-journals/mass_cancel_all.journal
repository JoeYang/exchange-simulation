# mass_cancel_all.journal
# Five resting orders (3 buys, 2 sells) from different accounts.
# MASS_CANCEL_ALL cancels every active order; book becomes empty.
CONFIG match_algo=FIFO tick_size=100 lot_size=10000 max_orders=1000 max_levels=100 max_order_ids=10000 price_band_low=0 price_band_high=0

ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=1 side=BUY price=990000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=1000 cl_ord_id=1 ord_id=1
EXPECT ORDER_BOOK_ACTION ts=1000 action=ADD qty=10000 price=990000 side=BUY ord_id=1
EXPECT DEPTH_UPDATE ts=1000 action=ADD count=1 qty=10000 price=990000 side=BUY
EXPECT TOP_OF_BOOK ts=1000 ask_qty=0 ask=0 bid_qty=10000 bid=990000

ACTION NEW_ORDER ts=2000 cl_ord_id=2 account_id=2 side=BUY price=1000000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=2000 cl_ord_id=2 ord_id=2
EXPECT ORDER_BOOK_ACTION ts=2000 action=ADD qty=10000 price=1000000 side=BUY ord_id=2
EXPECT DEPTH_UPDATE ts=2000 action=ADD count=1 qty=10000 price=1000000 side=BUY
EXPECT TOP_OF_BOOK ts=2000 ask_qty=0 ask=0 bid_qty=10000 bid=1000000

ACTION NEW_ORDER ts=3000 cl_ord_id=3 account_id=3 side=BUY price=1010000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=3000 cl_ord_id=3 ord_id=3
EXPECT ORDER_BOOK_ACTION ts=3000 action=ADD qty=10000 price=1010000 side=BUY ord_id=3
EXPECT DEPTH_UPDATE ts=3000 action=ADD count=1 qty=10000 price=1010000 side=BUY
EXPECT TOP_OF_BOOK ts=3000 ask_qty=0 ask=0 bid_qty=10000 bid=1010000

ACTION NEW_ORDER ts=4000 cl_ord_id=4 account_id=10 side=SELL price=1050000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=4000 cl_ord_id=4 ord_id=4
EXPECT ORDER_BOOK_ACTION ts=4000 action=ADD qty=10000 price=1050000 side=SELL ord_id=4
EXPECT DEPTH_UPDATE ts=4000 action=ADD count=1 qty=10000 price=1050000 side=SELL
EXPECT TOP_OF_BOOK ts=4000 ask_qty=10000 ask=1050000 bid_qty=10000 bid=1010000

ACTION NEW_ORDER ts=5000 cl_ord_id=5 account_id=11 side=SELL price=1060000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=5000 cl_ord_id=5 ord_id=5
EXPECT ORDER_BOOK_ACTION ts=5000 action=ADD qty=10000 price=1060000 side=SELL ord_id=5
EXPECT DEPTH_UPDATE ts=5000 action=ADD count=1 qty=10000 price=1060000 side=SELL
EXPECT TOP_OF_BOOK ts=5000 ask_qty=10000 ask=1050000 bid_qty=10000 bid=1010000

ACTION MASS_CANCEL_ALL ts=6000
EXPECT ORDER_CANCELLED reason=MASS_CANCELLED ts=6000 ord_id=1
EXPECT ORDER_CANCELLED reason=MASS_CANCELLED ts=6000 ord_id=2
EXPECT ORDER_CANCELLED reason=MASS_CANCELLED ts=6000 ord_id=3
EXPECT ORDER_CANCELLED reason=MASS_CANCELLED ts=6000 ord_id=4
EXPECT ORDER_CANCELLED reason=MASS_CANCELLED ts=6000 ord_id=5
EXPECT ORDER_BOOK_ACTION ts=6000 action=CANCEL qty=10000 price=990000 side=BUY ord_id=1
EXPECT DEPTH_UPDATE ts=6000 action=REMOVE count=0 qty=0 price=990000 side=BUY
EXPECT ORDER_BOOK_ACTION ts=6000 action=CANCEL qty=10000 price=1000000 side=BUY ord_id=2
EXPECT DEPTH_UPDATE ts=6000 action=REMOVE count=0 qty=0 price=1000000 side=BUY
EXPECT ORDER_BOOK_ACTION ts=6000 action=CANCEL qty=10000 price=1010000 side=BUY ord_id=3
EXPECT DEPTH_UPDATE ts=6000 action=REMOVE count=0 qty=0 price=1010000 side=BUY
EXPECT TOP_OF_BOOK ts=6000 ask_qty=10000 ask=1050000 bid_qty=0 bid=0
EXPECT ORDER_BOOK_ACTION ts=6000 action=CANCEL qty=10000 price=1050000 side=SELL ord_id=4
EXPECT DEPTH_UPDATE ts=6000 action=REMOVE count=0 qty=0 price=1050000 side=SELL
EXPECT TOP_OF_BOOK ts=6000 ask_qty=10000 ask=1060000 bid_qty=0 bid=0
EXPECT ORDER_BOOK_ACTION ts=6000 action=CANCEL qty=10000 price=1060000 side=SELL ord_id=5
EXPECT DEPTH_UPDATE ts=6000 action=REMOVE count=0 qty=0 price=1060000 side=SELL
EXPECT TOP_OF_BOOK ts=6000 ask_qty=0 ask=0 bid_qty=0 bid=0
