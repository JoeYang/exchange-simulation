# modify_price_change.journal
# A resting order's price is changed via a modify (cancel-replace). Under the
# CancelReplace policy, this removes the order from its old price level and
# re-inserts it at the new price, which causes it to lose time priority.
#
# Event ordering (test runner: all order events, then all md events):
# Order events: ORDER_MODIFIED
# MD events:
#   OBA(CANCEL at old price), DU(REMOVE at old price),
#   OBA(ADD at new price),    DU(ADD at new price),
#   TOP_OF_BOOK
#
# Note: the engine fires OBA(CANCEL)+DU before ORDER_MODIFIED, but the test
# runner collects order_listener and md_listener independently and concatenates
# them: all order events first, then all md events.

CONFIG match_algo=FIFO tick_size=100 lot_size=10000

# --- action 0: place a resting buy at 1005000 ---
ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=1 side=BUY price=1005000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ord_id=1 cl_ord_id=1 ts=1000
EXPECT ORDER_BOOK_ACTION ord_id=1 side=BUY price=1005000 qty=10000 action=ADD ts=1000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=10000 count=1 action=ADD ts=1000
EXPECT TOP_OF_BOOK bid=1005000 bid_qty=10000 ask=0 ask_qty=0 ts=1000

# --- action 1: modify price to 1006000 (cancel-replace, loses priority) ---
ACTION MODIFY ts=2000 ord_id=1 cl_ord_id=2 new_price=1006000 new_qty=10000
EXPECT ORDER_MODIFIED ord_id=1 cl_ord_id=2 new_price=1006000 new_qty=10000 ts=2000
EXPECT ORDER_BOOK_ACTION ord_id=1 side=BUY price=1005000 qty=10000 action=CANCEL ts=2000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=0 count=0 action=REMOVE ts=2000
EXPECT ORDER_BOOK_ACTION ord_id=1 side=BUY price=1006000 qty=10000 action=ADD ts=2000
EXPECT DEPTH_UPDATE side=BUY price=1006000 qty=10000 count=1 action=ADD ts=2000
EXPECT TOP_OF_BOOK bid=1006000 bid_qty=10000 ask=0 ask_qty=0 ts=2000
