# economics_multi_level_sweep.journal
# Verify sweep across multiple price levels.
# Ask book: 10@100.00, 20@100.50, 30@101.00.
# Aggressive buy market 60 lots sweeps all 3 levels.
# Each TRADE has the resting level's price.
# Total: 100000 + 200000 + 300000 = 600000.
CONFIG match_algo=FIFO tick_size=100 lot_size=10000 max_orders=1000 max_levels=100 max_order_ids=10000 price_band_low=0 price_band_high=0

ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=1 side=SELL price=1000000 qty=100000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=1000 cl_ord_id=1 ord_id=1
EXPECT ORDER_BOOK_ACTION ts=1000 action=ADD qty=100000 price=1000000 side=SELL ord_id=1
EXPECT DEPTH_UPDATE ts=1000 action=ADD count=1 qty=100000 price=1000000 side=SELL
EXPECT TOP_OF_BOOK ts=1000 ask_qty=100000 ask=1000000 bid_qty=0 bid=0

ACTION NEW_ORDER ts=2000 cl_ord_id=2 account_id=1 side=SELL price=1005000 qty=200000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=2000 cl_ord_id=2 ord_id=2
EXPECT ORDER_BOOK_ACTION ts=2000 action=ADD qty=200000 price=1005000 side=SELL ord_id=2
EXPECT DEPTH_UPDATE ts=2000 action=ADD count=1 qty=200000 price=1005000 side=SELL
EXPECT TOP_OF_BOOK ts=2000 ask_qty=100000 ask=1000000 bid_qty=0 bid=0

ACTION NEW_ORDER ts=3000 cl_ord_id=3 account_id=1 side=SELL price=1010000 qty=300000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=3000 cl_ord_id=3 ord_id=3
EXPECT ORDER_BOOK_ACTION ts=3000 action=ADD qty=300000 price=1010000 side=SELL ord_id=3
EXPECT DEPTH_UPDATE ts=3000 action=ADD count=1 qty=300000 price=1010000 side=SELL
EXPECT TOP_OF_BOOK ts=3000 ask_qty=100000 ask=1000000 bid_qty=0 bid=0

ACTION NEW_ORDER ts=4000 cl_ord_id=4 account_id=2 side=BUY price=0 qty=600000 type=MARKET tif=GTC
EXPECT ORDER_ACCEPTED ts=4000 cl_ord_id=4 ord_id=4
EXPECT ORDER_PARTIALLY_FILLED resting_rem=0 ts=4000 aggressor_rem=500000 qty=100000 price=1000000 resting=1 aggressor=4
EXPECT ORDER_PARTIALLY_FILLED resting_rem=0 ts=4000 aggressor_rem=300000 qty=200000 price=1005000 resting=2 aggressor=4
EXPECT ORDER_FILLED ts=4000 qty=300000 price=1010000 resting=3 aggressor=4
EXPECT TRADE ts=4000 aggressor_side=BUY resting=1 aggressor=4 qty=100000 price=1000000
EXPECT ORDER_BOOK_ACTION ts=4000 action=FILL qty=100000 price=1000000 side=SELL ord_id=1
EXPECT DEPTH_UPDATE ts=4000 action=REMOVE count=0 qty=0 price=1000000 side=SELL
EXPECT TRADE ts=4000 aggressor_side=BUY resting=2 aggressor=4 qty=200000 price=1005000
EXPECT ORDER_BOOK_ACTION ts=4000 action=FILL qty=200000 price=1005000 side=SELL ord_id=2
EXPECT DEPTH_UPDATE ts=4000 action=REMOVE count=0 qty=0 price=1005000 side=SELL
EXPECT TRADE ts=4000 aggressor_side=BUY resting=3 aggressor=4 qty=300000 price=1010000
EXPECT ORDER_BOOK_ACTION ts=4000 action=FILL qty=300000 price=1010000 side=SELL ord_id=3
EXPECT DEPTH_UPDATE ts=4000 action=REMOVE count=0 qty=0 price=1010000 side=SELL
EXPECT TOP_OF_BOOK ts=4000 ask_qty=0 ask=0 bid_qty=0 bid=0
