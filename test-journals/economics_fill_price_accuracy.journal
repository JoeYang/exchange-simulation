# economics_fill_price_accuracy.journal
# Verify fill price is always the resting order's price.
# Subtest 1: Sell rests @ 100.5000, Buy crosses @ 101.0000
#   -> fill at 100.5000 (resting sell price)
# Subtest 2: Buy rests @ 99.5000, Sell crosses @ 99.0000
#   -> fill at 99.5000 (resting buy price)
CONFIG match_algo=FIFO tick_size=100 lot_size=10000 max_orders=1000 max_levels=100 max_order_ids=10000 price_band_low=0 price_band_high=0

ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=1 side=SELL price=1005000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=1000 cl_ord_id=1 ord_id=1
EXPECT ORDER_BOOK_ACTION ts=1000 action=ADD qty=10000 price=1005000 side=SELL ord_id=1
EXPECT DEPTH_UPDATE ts=1000 action=ADD count=1 qty=10000 price=1005000 side=SELL
EXPECT TOP_OF_BOOK ts=1000 ask_qty=10000 ask=1005000 bid_qty=0 bid=0

ACTION NEW_ORDER ts=2000 cl_ord_id=2 account_id=2 side=BUY price=1010000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=2000 cl_ord_id=2 ord_id=2
EXPECT ORDER_FILLED ts=2000 qty=10000 price=1005000 resting=1 aggressor=2
EXPECT TRADE ts=2000 aggressor_side=BUY resting=1 aggressor=2 qty=10000 price=1005000
EXPECT ORDER_BOOK_ACTION ts=2000 action=FILL qty=10000 price=1005000 side=SELL ord_id=1
EXPECT DEPTH_UPDATE ts=2000 action=REMOVE count=0 qty=0 price=1005000 side=SELL
EXPECT TOP_OF_BOOK ts=2000 ask_qty=0 ask=0 bid_qty=0 bid=0

ACTION NEW_ORDER ts=3000 cl_ord_id=3 account_id=3 side=BUY price=995000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=3000 cl_ord_id=3 ord_id=3
EXPECT ORDER_BOOK_ACTION ts=3000 action=ADD qty=10000 price=995000 side=BUY ord_id=3
EXPECT DEPTH_UPDATE ts=3000 action=ADD count=1 qty=10000 price=995000 side=BUY
EXPECT TOP_OF_BOOK ts=3000 ask_qty=0 ask=0 bid_qty=10000 bid=995000

ACTION NEW_ORDER ts=4000 cl_ord_id=4 account_id=4 side=SELL price=990000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=4000 cl_ord_id=4 ord_id=4
EXPECT ORDER_FILLED ts=4000 qty=10000 price=995000 resting=3 aggressor=4
EXPECT TRADE ts=4000 aggressor_side=SELL resting=3 aggressor=4 qty=10000 price=995000
EXPECT ORDER_BOOK_ACTION ts=4000 action=FILL qty=10000 price=995000 side=BUY ord_id=3
EXPECT DEPTH_UPDATE ts=4000 action=REMOVE count=0 qty=0 price=995000 side=BUY
EXPECT TOP_OF_BOOK ts=4000 ask_qty=0 ask=0 bid_qty=0 bid=0
