# Rate throttle: 3 messages per 1-second window
CONFIG tick_size=100 lot_size=10000 rate_limit=3 rate_interval=1000000000

# 1st order accepted (account 1)
ACTION NEW_ORDER cl_ord_id=1 account_id=1 side=BUY type=LIMIT price=1000000 qty=10000 ts=1
EXPECT ORDER_ACCEPTED ord_id=1 cl_ord_id=1 ts=1
EXPECT ORDER_BOOK_ACTION ord_id=1 side=BUY price=1000000 qty=10000 action=ADD ts=1
EXPECT DEPTH_UPDATE side=BUY price=1000000 qty=10000 count=1 action=ADD ts=1
EXPECT TOP_OF_BOOK bid=1000000 bid_qty=10000 ask=0 ask_qty=0 ts=1

# 2nd order accepted at worse price
ACTION NEW_ORDER cl_ord_id=2 account_id=1 side=BUY type=LIMIT price=990000 qty=10000 ts=2
EXPECT ORDER_ACCEPTED ord_id=2 cl_ord_id=2 ts=2
EXPECT ORDER_BOOK_ACTION ord_id=2 side=BUY price=990000 qty=10000 action=ADD ts=2
EXPECT DEPTH_UPDATE side=BUY price=990000 qty=10000 count=1 action=ADD ts=2
EXPECT TOP_OF_BOOK bid=1000000 bid_qty=10000 ask=0 ask_qty=0 ts=2

# 3rd order accepted (at limit)
ACTION NEW_ORDER cl_ord_id=3 account_id=1 side=BUY type=LIMIT price=980000 qty=10000 ts=3
EXPECT ORDER_ACCEPTED ord_id=3 cl_ord_id=3 ts=3
EXPECT ORDER_BOOK_ACTION ord_id=3 side=BUY price=980000 qty=10000 action=ADD ts=3
EXPECT DEPTH_UPDATE side=BUY price=980000 qty=10000 count=1 action=ADD ts=3
EXPECT TOP_OF_BOOK bid=1000000 bid_qty=10000 ask=0 ask_qty=0 ts=3

# 4th order within same window -- rate throttled (only order event, no MD events)
ACTION NEW_ORDER cl_ord_id=4 account_id=1 side=BUY type=LIMIT price=970000 qty=10000 ts=4
EXPECT ORDER_REJECTED cl_ord_id=4 ts=4 reason=RATE_THROTTLED

# After window expires (ts >= 1 + 1_000_000_000), orders accepted again
ACTION NEW_ORDER cl_ord_id=5 account_id=1 side=BUY type=LIMIT price=960000 qty=10000 ts=1000000005
EXPECT ORDER_ACCEPTED ord_id=4 cl_ord_id=5 ts=1000000005
EXPECT ORDER_BOOK_ACTION ord_id=4 side=BUY price=960000 qty=10000 action=ADD ts=1000000005
EXPECT DEPTH_UPDATE side=BUY price=960000 qty=10000 count=1 action=ADD ts=1000000005
EXPECT TOP_OF_BOOK bid=1000000 bid_qty=10000 ask=0 ask_qty=0 ts=1000000005
