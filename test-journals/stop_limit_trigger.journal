# stop_limit_trigger.journal
# A stop-limit order triggers and then rests on the book (no immediate fill).
#
# Setup:
#   ord1: limit sell at 1005000 (rests)
#   ord2: buy stop-limit, stop_price=1005000, limit_price=1006000 (rests in stop book)
#
# Trigger action:
#   ord3: limit buy at 1005000 fills ord1 -> trade at 1005000
#   last_trade = 1005000 >= stop_price 1005000 -> stop-limit triggers
#   ord2 becomes a limit buy at 1006000, no asks present -> rests on book
#
# Event ordering for trigger action (all order events, then all MD events):
# Order: ORDER_ACCEPTED(ord3), ORDER_FILLED(ord3 vs ord1)
# MD:    TRADE, OBA(FILL,ord1), DU(REMOVE,ask),
#        [stop triggers, becomes limit, rests]:
#        OBA(ADD,ord2 at 1006000), DU(ADD,bid 1006000), TOP_OF_BOOK
#
# Important: check_and_trigger_stops calls match_order for the triggered stop,
# which calls insert_into_book, which fires OBA(ADD) and DU(ADD).
# Then post_match calls fire_top_of_book (always fires when order rests).
# These MD events are appended AFTER the initial fill MD events.
CONFIG match_algo=FIFO tick_size=100 lot_size=10000

# Action 0: limit sell rests
ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=0 side=SELL price=1005000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ord_id=1 cl_ord_id=1 ts=1000
EXPECT ORDER_BOOK_ACTION ord_id=1 side=SELL price=1005000 qty=10000 action=ADD ts=1000
EXPECT DEPTH_UPDATE side=SELL price=1005000 qty=10000 count=1 action=ADD ts=1000
EXPECT TOP_OF_BOOK bid=0 bid_qty=0 ask=1005000 ask_qty=10000 ts=1000

# Action 1: buy stop-limit (stop_price=1005000, limit_price=1006000)
# No MD events -- stop book only.
ACTION NEW_ORDER ts=1001 cl_ord_id=2 account_id=0 side=BUY price=1006000 qty=10000 type=STOP_LIMIT tif=GTC stop_price=1005000
EXPECT ORDER_ACCEPTED ord_id=2 cl_ord_id=2 ts=1001

# Action 2: limit buy fills ord1 -> triggers stop-limit -> stop-limit rests as limit
# Order events: ORDER_ACCEPTED(ord3), ORDER_FILLED(ord3 vs ord1)
# MD events:
#   From initial fill: TRADE, OBA(FILL,ord1), DU(REMOVE,ask)
#   From triggered stop-limit resting: OBA(ADD,ord2), DU(ADD,bid), TOP_OF_BOOK
# Note: fire_top_of_book_if_changed after initial fill: ask was 1005000, now 0
#   -> fires TOP_OF_BOOK(bid=0, ask=0) here? No -- post_match for ord3 (fully filled)
#   calls fire_top_of_book_if_changed. old_best_ask=1005000, new=0 -> fires TOB.
#   But THEN check_and_trigger_stops runs, which calls match_order for ord2.
#   match_order for ord2 (limit buy at 1006000, no asks) -> insert_into_book
#   -> fire_top_of_book (unconditional). So two TOP_OF_BOOK events fire.
#
# Correction: post_match is called within match_order. After matching ord3,
# post_match fires fire_top_of_book_if_changed (old_ask=1005000 -> new=0).
# Then check_and_trigger_stops runs the triggered ord2 through match_order.
# match_order for ord2: no asks -> post_match -> insert_into_book -> fire_top_of_book.
# So: TOB(bid=0,ask=0) from ord3's fill, then TOB(bid=1006000,ask=0) from ord2 resting.
ACTION NEW_ORDER ts=2000 cl_ord_id=3 account_id=0 side=BUY price=1005000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ord_id=3 cl_ord_id=3 ts=2000
EXPECT ORDER_FILLED aggressor=3 resting=1 price=1005000 qty=10000 ts=2000
EXPECT TRADE price=1005000 qty=10000 aggressor=3 resting=1 aggressor_side=BUY ts=2000
EXPECT ORDER_BOOK_ACTION ord_id=1 side=SELL price=1005000 qty=10000 action=FILL ts=2000
EXPECT DEPTH_UPDATE side=SELL price=1005000 qty=0 count=0 action=REMOVE ts=2000
EXPECT TOP_OF_BOOK bid=0 bid_qty=0 ask=0 ask_qty=0 ts=2000
EXPECT ORDER_BOOK_ACTION ord_id=2 side=BUY price=1006000 qty=10000 action=ADD ts=2000
EXPECT DEPTH_UPDATE side=BUY price=1006000 qty=10000 count=1 action=ADD ts=2000
EXPECT TOP_OF_BOOK bid=1006000 bid_qty=10000 ask=0 ask_qty=0 ts=2000
