# L3 (OrderBookAction) verification: every individual order event produces an
# OrderBookAction with the correct action field.
# ADD: order rests on the book.
# CANCEL: order explicitly cancelled by user.
# FILL: order's quantity consumed by a trade (fully or partially).
# MODIFY: order changed by a modify request (cancel-replace flow fires CANCEL then ADD).
CONFIG match_algo=FIFO tick_size=100 lot_size=10000

# ADD: limit buy rests
ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=1 side=BUY price=1005000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ord_id=1 cl_ord_id=1 ts=1000
EXPECT ORDER_BOOK_ACTION ord_id=1 side=BUY price=1005000 qty=10000 action=ADD ts=1000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=10000 count=1 action=ADD ts=1000
EXPECT TOP_OF_BOOK bid=1005000 bid_qty=10000 ask=0 ask_qty=0 ts=1000

# ADD: second limit buy rests
ACTION NEW_ORDER ts=2000 cl_ord_id=2 account_id=1 side=BUY price=1005000 qty=20000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ord_id=2 cl_ord_id=2 ts=2000
EXPECT ORDER_BOOK_ACTION ord_id=2 side=BUY price=1005000 qty=20000 action=ADD ts=2000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=30000 count=2 action=UPDATE ts=2000
EXPECT TOP_OF_BOOK bid=1005000 bid_qty=30000 ask=0 ask_qty=0 ts=2000

# CANCEL: user cancels ord_id=2
ACTION CANCEL ts=3000 ord_id=2
EXPECT ORDER_CANCELLED ord_id=2 ts=3000 reason=USER_REQUESTED
EXPECT ORDER_BOOK_ACTION ord_id=2 side=BUY price=1005000 qty=20000 action=CANCEL ts=3000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=10000 count=1 action=UPDATE ts=3000

# MODIFY (cancel-replace): modify ord_id=1 to a new price, loses priority.
# Fires OrderBookAction CANCEL for the old order, then ADD for the new slot.
ACTION MODIFY ts=4000 ord_id=1 cl_ord_id=10 new_price=1000000 new_qty=10000
EXPECT ORDER_MODIFIED ord_id=1 cl_ord_id=10 new_price=1000000 new_qty=10000 ts=4000
EXPECT ORDER_BOOK_ACTION ord_id=1 side=BUY price=1005000 qty=10000 action=CANCEL ts=4000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=0 count=0 action=REMOVE ts=4000
EXPECT ORDER_BOOK_ACTION ord_id=1 side=BUY price=1000000 qty=10000 action=ADD ts=4000
EXPECT DEPTH_UPDATE side=BUY price=1000000 qty=10000 count=1 action=ADD ts=4000
EXPECT TOP_OF_BOOK bid=1000000 bid_qty=10000 ask=0 ask_qty=0 ts=4000

# ADD: resting sell at 1000000 to set up the fill
ACTION NEW_ORDER ts=5000 cl_ord_id=3 account_id=2 side=SELL price=1000000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ord_id=3 cl_ord_id=3 ts=5000
EXPECT ORDER_FILLED aggressor=3 resting=1 price=1000000 qty=10000 ts=5000
EXPECT TRADE price=1000000 qty=10000 aggressor=3 resting=1 aggressor_side=SELL ts=5000
# FILL: ord_id=1 fully consumed
EXPECT ORDER_BOOK_ACTION ord_id=1 side=BUY price=1000000 qty=10000 action=FILL ts=5000
EXPECT DEPTH_UPDATE side=BUY price=1000000 qty=0 count=0 action=REMOVE ts=5000
EXPECT TOP_OF_BOOK bid=0 bid_qty=0 ask=0 ask_qty=0 ts=5000
