# DAY order expires via TRIGGER_EXPIRY action with tif=DAY.
# All DAY orders on the book are cancelled with CancelReason::Expired.
# GTC order at the same price level survives the expiry event.
CONFIG match_algo=FIFO tick_size=100 lot_size=10000

# GTC order rests — should survive the DAY expiry sweep
ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=1 side=BUY price=1005000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ord_id=1 cl_ord_id=1 ts=1000
EXPECT ORDER_BOOK_ACTION ord_id=1 side=BUY price=1005000 qty=10000 action=ADD ts=1000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=10000 count=1 action=ADD ts=1000
EXPECT TOP_OF_BOOK bid=1005000 bid_qty=10000 ask=0 ask_qty=0 ts=1000

# DAY order rests at the same price level
ACTION NEW_ORDER ts=2000 cl_ord_id=2 account_id=2 side=BUY price=1005000 qty=20000 type=LIMIT tif=DAY
EXPECT ORDER_ACCEPTED ord_id=2 cl_ord_id=2 ts=2000
EXPECT ORDER_BOOK_ACTION ord_id=2 side=BUY price=1005000 qty=20000 action=ADD ts=2000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=30000 count=2 action=UPDATE ts=2000
EXPECT TOP_OF_BOOK bid=1005000 bid_qty=30000 ask=0 ask_qty=0 ts=2000

# Trigger DAY expiry — only the DAY order (ord_id=2) is cancelled; GTC (ord_id=1) survives
ACTION TRIGGER_EXPIRY ts=86400000000000 tif=DAY
EXPECT ORDER_CANCELLED ord_id=2 ts=86400000000000 reason=EXPIRED
EXPECT ORDER_BOOK_ACTION ord_id=2 side=BUY price=1005000 qty=20000 action=CANCEL ts=86400000000000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=10000 count=1 action=UPDATE ts=86400000000000
