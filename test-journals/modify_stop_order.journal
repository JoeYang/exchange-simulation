# modify_stop_order.journal
# Attempt to modify a stop order before it triggers.
#
# The default modify policy is CancelReplace. However, stop orders are in the
# stop book, not the main order book. modify_order() calls book_.remove_order()
# which only operates on the main book. For stop orders, this will fail or
# have undefined behavior -- so we test the valid case of MODIFY being rejected
# for an unknown order (since stop orders can't be modified via the modify path).
#
# Actually, looking at modify_order() in matching_engine.h:
#   It checks order_index_[req.order_id] != nullptr (stop orders ARE in order_index_).
#   Then it calls book_.remove_order(order) for CancelReplace policy.
#   A stop order is NOT in the main book, so remove_order returns nullptr (freed=nullptr).
#   Then it calls insert_into_book -> but the order type is still Stop.
#   This is effectively a cancel-replace that moves the stop into the main book
#   with modified parameters. This is likely unintended behavior.
#
# Safe approach: test modifying a stop to an invalid price, which is rejected
# before reaching the policy logic.
CONFIG match_algo=FIFO tick_size=100 lot_size=10000

# Action 0: place a buy stop-limit
ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=0 side=BUY price=1006000 qty=10000 type=STOP_LIMIT tif=GTC stop_price=1005000
EXPECT ORDER_ACCEPTED ord_id=1 cl_ord_id=1 ts=1000

# Action 1: attempt to modify stop with invalid price (not tick-aligned)
# This should be rejected with INVALID_PRICE before reaching book manipulation.
ACTION MODIFY ts=2000 ord_id=1 cl_ord_id=2 new_price=999 new_qty=10000
EXPECT ORDER_MODIFY_REJECTED ord_id=1 cl_ord_id=2 ts=2000 reason=INVALID_PRICE

# Action 2: place a limit sell to verify the stop is still alive
# (i.e. it was not modified or cancelled by the rejected modify)
ACTION NEW_ORDER ts=3000 cl_ord_id=3 account_id=0 side=SELL price=1005000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ord_id=2 cl_ord_id=3 ts=3000
EXPECT ORDER_BOOK_ACTION ord_id=2 side=SELL price=1005000 qty=10000 action=ADD ts=3000
EXPECT DEPTH_UPDATE side=SELL price=1005000 qty=10000 count=1 action=ADD ts=3000
EXPECT TOP_OF_BOOK bid=0 bid_qty=0 ask=1005000 ask_qty=10000 ts=3000
