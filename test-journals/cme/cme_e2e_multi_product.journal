# CME: Multi-product — ES + NQ simultaneous, cross-instrument isolation
CONFIG match_algo=FIFO instrument=ES tick_size=2500 lot_size=10000

ACTION SESSION_START ts=0 state=CONTINUOUS

ACTION ILINK3_NEW_ORDER ts=1000 instrument=ES cl_ord_id=1 account=FIRM_A side=BUY price=50000000 qty=10000 type=LIMIT tif=DAY
EXPECT EXEC_NEW cl_ord_id=1 status=NEW
EXPECT MD_BOOK_ADD side=BUY price=5000000000000 qty=1 num_orders=1
EXPECT MD_BOOK_UPDATE side=BUY price=5000000000000 qty=1 num_orders=2147483647

ACTION ILINK3_NEW_ORDER ts=1001 instrument=NQ cl_ord_id=2 account=FIRM_A side=BUY price=18000000 qty=10000 type=LIMIT tif=DAY
EXPECT EXEC_NEW cl_ord_id=2 status=NEW
EXPECT MD_BOOK_ADD side=BUY price=1800000000000 qty=1 num_orders=1
EXPECT MD_BOOK_UPDATE side=BUY price=1800000000000 qty=1 num_orders=2147483647

# Fill on ES only — NQ should be unaffected
ACTION ILINK3_NEW_ORDER ts=2000 instrument=ES cl_ord_id=3 account=FIRM_B side=SELL price=50000000 qty=10000 type=LIMIT tif=DAY
EXPECT EXEC_NEW cl_ord_id=3 status=NEW
EXPECT EXEC_FILL cl_ord_id=2 fill_price=5000000000000 fill_qty=1 leaves_qty=0 status=FILLED
EXPECT EXEC_FILL cl_ord_id=3 fill_price=5000000000000 fill_qty=1 leaves_qty=0 status=FILLED
EXPECT MD_TRADE price=5000000000000 qty=1 aggressor_side=SELL
EXPECT MD_BOOK_DELETE side=BUY price=5000000000000 qty=0 num_orders=0
EXPECT MD_BOOK_UPDATE side=BUY price=9223372036854775807 qty=0 num_orders=2147483647
