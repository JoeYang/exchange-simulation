# CME: Market order sweeps multiple resting levels
CONFIG match_algo=FIFO instrument=ES tick_size=2500 lot_size=10000

ACTION SESSION_START ts=0 state=CONTINUOUS

# Build 3 levels of resting asks
ACTION ILINK3_NEW_ORDER ts=1000 instrument=ES cl_ord_id=1 account=FIRM_A side=SELL price=50000000 qty=10000 type=LIMIT tif=DAY
EXPECT EXEC_NEW cl_ord_id=1 status=NEW
EXPECT MD_BOOK_ADD side=SELL price=5000000000000 qty=1 num_orders=1
EXPECT MD_BOOK_UPDATE side=BUY price=9223372036854775807 qty=0 num_orders=2147483647

ACTION ILINK3_NEW_ORDER ts=1001 instrument=ES cl_ord_id=2 account=FIRM_A side=SELL price=50002500 qty=10000 type=LIMIT tif=DAY
EXPECT EXEC_NEW cl_ord_id=2 status=NEW
EXPECT MD_BOOK_ADD side=SELL price=5000250000000 qty=1 num_orders=1
EXPECT MD_BOOK_UPDATE side=BUY price=9223372036854775807 qty=0 num_orders=2147483647

ACTION ILINK3_NEW_ORDER ts=1002 instrument=ES cl_ord_id=3 account=FIRM_A side=SELL price=50005000 qty=10000 type=LIMIT tif=DAY
EXPECT EXEC_NEW cl_ord_id=3 status=NEW
EXPECT MD_BOOK_ADD side=SELL price=5000500000000 qty=1 num_orders=1
EXPECT MD_BOOK_UPDATE side=BUY price=9223372036854775807 qty=0 num_orders=2147483647

# Market buy sweeps all 3 levels
ACTION ILINK3_NEW_ORDER ts=2000 instrument=ES cl_ord_id=4 account=FIRM_B side=BUY price=0 qty=30000 type=MARKET tif=IOC
EXPECT EXEC_NEW cl_ord_id=4 status=NEW
EXPECT EXEC_FILL cl_ord_id=1 fill_price=5000000000000 fill_qty=1 leaves_qty=0 status=FILLED
EXPECT EXEC_FILL cl_ord_id=4 fill_price=5000000000000 fill_qty=1 leaves_qty=1 status=PARTIAL
EXPECT EXEC_FILL cl_ord_id=2 fill_price=5000250000000 fill_qty=1 leaves_qty=0 status=FILLED
EXPECT EXEC_FILL cl_ord_id=4 fill_price=5000250000000 fill_qty=1 leaves_qty=0 status=FILLED
EXPECT EXEC_FILL cl_ord_id=3 fill_price=5000500000000 fill_qty=1 leaves_qty=0 status=FILLED
EXPECT EXEC_FILL cl_ord_id=4 fill_price=5000500000000 fill_qty=1 leaves_qty=0 status=FILLED
EXPECT MD_TRADE price=5000000000000 qty=1 aggressor_side=BUY
EXPECT MD_BOOK_DELETE side=SELL price=5000000000000 qty=0 num_orders=0
EXPECT MD_TRADE price=5000250000000 qty=1 aggressor_side=BUY
EXPECT MD_BOOK_DELETE side=SELL price=5000250000000 qty=0 num_orders=0
EXPECT MD_TRADE price=5000500000000 qty=1 aggressor_side=BUY
EXPECT MD_BOOK_DELETE side=SELL price=5000500000000 qty=0 num_orders=0
EXPECT MD_BOOK_UPDATE side=BUY price=9223372036854775807 qty=0 num_orders=2147483647
