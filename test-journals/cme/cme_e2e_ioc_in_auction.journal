# CME: IOC rejected during PreOpen auction collection
CONFIG match_algo=FIFO instrument=ES tick_size=2500 lot_size=10000

ACTION SESSION_START ts=0 state=PRE_OPEN

ACTION ILINK3_NEW_ORDER ts=1000 instrument=ES cl_ord_id=1 account=FIRM_A side=BUY price=50000000 qty=10000 type=LIMIT tif=IOC
EXPECT EXEC_REJECTED cl_ord_id=1
