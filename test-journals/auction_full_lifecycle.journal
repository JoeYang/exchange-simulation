# auction_full_lifecycle.journal
# Full session: Closed -> PreOpen -> collect -> indicative ->
# execute_auction -> Continuous -> normal matching fill.
CONFIG match_algo=FIFO tick_size=100 lot_size=10000 max_orders=1000 max_levels=100 max_order_ids=10000 price_band_low=0 price_band_high=0

ACTION SET_SESSION_STATE ts=1000 state=PRE_OPEN
EXPECT MARKET_STATUS ts=1000 state=PRE_OPEN

ACTION NEW_ORDER ts=2000 cl_ord_id=1 account_id=1 side=BUY price=1010000 qty=100000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=2000 cl_ord_id=1 ord_id=1
EXPECT ORDER_BOOK_ACTION ts=2000 action=ADD qty=100000 price=1010000 side=BUY ord_id=1
EXPECT DEPTH_UPDATE ts=2000 action=ADD count=1 qty=100000 price=1010000 side=BUY
EXPECT TOP_OF_BOOK ts=2000 ask_qty=0 ask=0 bid_qty=100000 bid=1010000

ACTION NEW_ORDER ts=3000 cl_ord_id=2 account_id=2 side=SELL price=990000 qty=100000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=3000 cl_ord_id=2 ord_id=2
EXPECT ORDER_BOOK_ACTION ts=3000 action=ADD qty=100000 price=990000 side=SELL ord_id=2
EXPECT DEPTH_UPDATE ts=3000 action=ADD count=1 qty=100000 price=990000 side=SELL
EXPECT TOP_OF_BOOK ts=3000 ask_qty=100000 ask=990000 bid_qty=100000 bid=1010000

ACTION PUBLISH_INDICATIVE ts=4000 reference_price=1000000
EXPECT INDICATIVE_PRICE ts=4000 sell_surplus=0 buy_surplus=0 matched_vol=100000 price=1010000

ACTION EXECUTE_AUCTION ts=5000 reference_price=1000000
EXPECT ORDER_FILLED ts=5000 qty=100000 price=1010000 resting=2 aggressor=1
EXPECT TRADE ts=5000 aggressor_side=BUY resting=2 aggressor=1 qty=100000 price=1010000
EXPECT ORDER_BOOK_ACTION ts=5000 action=FILL qty=100000 price=1010000 side=BUY ord_id=1
EXPECT ORDER_BOOK_ACTION ts=5000 action=FILL qty=100000 price=1010000 side=SELL ord_id=2
EXPECT DEPTH_UPDATE ts=5000 action=REMOVE count=0 qty=0 price=1010000 side=BUY
EXPECT DEPTH_UPDATE ts=5000 action=REMOVE count=0 qty=0 price=990000 side=SELL
EXPECT TOP_OF_BOOK ts=5000 ask_qty=0 ask=0 bid_qty=0 bid=0

ACTION SET_SESSION_STATE ts=6000 state=CONTINUOUS
EXPECT MARKET_STATUS ts=6000 state=CONTINUOUS

ACTION NEW_ORDER ts=7000 cl_ord_id=3 account_id=1 side=BUY price=1010000 qty=50000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=7000 cl_ord_id=3 ord_id=3
EXPECT ORDER_BOOK_ACTION ts=7000 action=ADD qty=50000 price=1010000 side=BUY ord_id=3
EXPECT DEPTH_UPDATE ts=7000 action=ADD count=1 qty=50000 price=1010000 side=BUY
EXPECT TOP_OF_BOOK ts=7000 ask_qty=0 ask=0 bid_qty=50000 bid=1010000

ACTION NEW_ORDER ts=8000 cl_ord_id=4 account_id=2 side=SELL price=1010000 qty=50000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=8000 cl_ord_id=4 ord_id=4
EXPECT ORDER_FILLED ts=8000 qty=50000 price=1010000 resting=3 aggressor=4
EXPECT TRADE ts=8000 aggressor_side=SELL resting=3 aggressor=4 qty=50000 price=1010000
EXPECT ORDER_BOOK_ACTION ts=8000 action=FILL qty=50000 price=1010000 side=BUY ord_id=3
EXPECT DEPTH_UPDATE ts=8000 action=REMOVE count=0 qty=0 price=1010000 side=BUY
EXPECT TOP_OF_BOOK ts=8000 ask_qty=0 ask=0 bid_qty=0 bid=0
