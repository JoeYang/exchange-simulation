# market_order_sweep.journal
# Market buy fills across 3 resting sell price levels.
# Levels: 1005000 (10000), 1006000 (10000), 1007000 (10000).
# Market buy for 30000 sweeps all three levels.
CONFIG match_algo=FIFO tick_size=100 lot_size=10000

# Action 0: sell at level 1 (best ask)
ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=0 side=SELL price=1005000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ord_id=1 cl_ord_id=1 ts=1000
EXPECT ORDER_BOOK_ACTION ord_id=1 side=SELL price=1005000 qty=10000 action=ADD ts=1000
EXPECT DEPTH_UPDATE side=SELL price=1005000 qty=10000 count=1 action=ADD ts=1000
EXPECT TOP_OF_BOOK bid=0 bid_qty=0 ask=1005000 ask_qty=10000 ts=1000

# Action 1: sell at level 2 (new ask level added; TOP_OF_BOOK always fires on insert)
ACTION NEW_ORDER ts=1001 cl_ord_id=2 account_id=0 side=SELL price=1006000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ord_id=2 cl_ord_id=2 ts=1001
EXPECT ORDER_BOOK_ACTION ord_id=2 side=SELL price=1006000 qty=10000 action=ADD ts=1001
EXPECT DEPTH_UPDATE side=SELL price=1006000 qty=10000 count=1 action=ADD ts=1001
EXPECT TOP_OF_BOOK bid=0 bid_qty=0 ask=1005000 ask_qty=10000 ts=1001

# Action 2: sell at level 3 (new ask level added; TOP_OF_BOOK always fires on insert)
ACTION NEW_ORDER ts=1002 cl_ord_id=3 account_id=0 side=SELL price=1007000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ord_id=3 cl_ord_id=3 ts=1002
EXPECT ORDER_BOOK_ACTION ord_id=3 side=SELL price=1007000 qty=10000 action=ADD ts=1002
EXPECT DEPTH_UPDATE side=SELL price=1007000 qty=10000 count=1 action=ADD ts=1002
EXPECT TOP_OF_BOOK bid=0 bid_qty=0 ask=1005000 ask_qty=10000 ts=1002

# Action 3: market buy sweeps all 3 levels (total 30000 qty)
# Order events (all first): ORDER_ACCEPTED, ORDER_FILLED (fully filled after 3rd level)
# MD events (all after): for each fill in order:
#   TRADE(level1), OBA(FILL,ord1), DU(REMOVE,1005000),
#   TRADE(level2), OBA(FILL,ord2), DU(REMOVE,1006000),
#   TRADE(level3), OBA(FILL,ord3), DU(REMOVE,1007000),
#   TOP_OF_BOOK (ask was 1005000, now 0)
ACTION NEW_ORDER ts=2000 cl_ord_id=4 account_id=0 side=BUY price=0 qty=30000 type=MARKET tif=GTC
EXPECT ORDER_ACCEPTED ord_id=4 cl_ord_id=4 ts=2000
EXPECT ORDER_PARTIALLY_FILLED aggressor=4 resting=1 price=1005000 qty=10000 aggressor_rem=20000 resting_rem=0 ts=2000
EXPECT ORDER_PARTIALLY_FILLED aggressor=4 resting=2 price=1006000 qty=10000 aggressor_rem=10000 resting_rem=0 ts=2000
EXPECT ORDER_FILLED aggressor=4 resting=3 price=1007000 qty=10000 ts=2000
EXPECT TRADE price=1005000 qty=10000 aggressor=4 resting=1 aggressor_side=BUY ts=2000
EXPECT ORDER_BOOK_ACTION ord_id=1 side=SELL price=1005000 qty=10000 action=FILL ts=2000
EXPECT DEPTH_UPDATE side=SELL price=1005000 qty=0 count=0 action=REMOVE ts=2000
EXPECT TRADE price=1006000 qty=10000 aggressor=4 resting=2 aggressor_side=BUY ts=2000
EXPECT ORDER_BOOK_ACTION ord_id=2 side=SELL price=1006000 qty=10000 action=FILL ts=2000
EXPECT DEPTH_UPDATE side=SELL price=1006000 qty=0 count=0 action=REMOVE ts=2000
EXPECT TRADE price=1007000 qty=10000 aggressor=4 resting=3 aggressor_side=BUY ts=2000
EXPECT ORDER_BOOK_ACTION ord_id=3 side=SELL price=1007000 qty=10000 action=FILL ts=2000
EXPECT DEPTH_UPDATE side=SELL price=1007000 qty=0 count=0 action=REMOVE ts=2000
EXPECT TOP_OF_BOOK bid=0 bid_qty=0 ask=0 ask_qty=0 ts=2000
