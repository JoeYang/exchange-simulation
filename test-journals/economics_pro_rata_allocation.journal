# economics_pro_rata_allocation.journal
# Verify pro-rata allocation math is exact.
# 3 resting orders: 100, 200, 300 lots at same price (total 600).
# Aggressor 1: 300 lots -> 50, 100, 150 (exact, no remainder).
# Aggressor 2: 100 lots -> 166667, 333333, 500000 = 1000000.
# Remainder (1) goes to first order in FIFO order.
CONFIG match_algo=PRO_RATA tick_size=100 lot_size=10000 max_orders=1000 max_levels=100 max_order_ids=10000 price_band_low=0 price_band_high=0

ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=1 side=BUY price=1000000 qty=1000000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=1000 cl_ord_id=1 ord_id=1
EXPECT ORDER_BOOK_ACTION ts=1000 action=ADD qty=1000000 price=1000000 side=BUY ord_id=1
EXPECT DEPTH_UPDATE ts=1000 action=ADD count=1 qty=1000000 price=1000000 side=BUY
EXPECT TOP_OF_BOOK ts=1000 ask_qty=0 ask=0 bid_qty=1000000 bid=1000000

ACTION NEW_ORDER ts=2000 cl_ord_id=2 account_id=1 side=BUY price=1000000 qty=2000000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=2000 cl_ord_id=2 ord_id=2
EXPECT ORDER_BOOK_ACTION ts=2000 action=ADD qty=2000000 price=1000000 side=BUY ord_id=2
EXPECT DEPTH_UPDATE ts=2000 action=UPDATE count=2 qty=3000000 price=1000000 side=BUY
EXPECT TOP_OF_BOOK ts=2000 ask_qty=0 ask=0 bid_qty=3000000 bid=1000000

ACTION NEW_ORDER ts=3000 cl_ord_id=3 account_id=1 side=BUY price=1000000 qty=3000000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=3000 cl_ord_id=3 ord_id=3
EXPECT ORDER_BOOK_ACTION ts=3000 action=ADD qty=3000000 price=1000000 side=BUY ord_id=3
EXPECT DEPTH_UPDATE ts=3000 action=UPDATE count=3 qty=6000000 price=1000000 side=BUY
EXPECT TOP_OF_BOOK ts=3000 ask_qty=0 ask=0 bid_qty=6000000 bid=1000000

ACTION NEW_ORDER ts=4000 cl_ord_id=4 account_id=2 side=SELL price=1000000 qty=3000000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=4000 cl_ord_id=4 ord_id=4
EXPECT ORDER_FILLED ts=4000 qty=500000 price=1000000 resting=1 aggressor=4
EXPECT ORDER_FILLED ts=4000 qty=1000000 price=1000000 resting=2 aggressor=4
EXPECT ORDER_FILLED ts=4000 qty=1500000 price=1000000 resting=3 aggressor=4
EXPECT TRADE ts=4000 aggressor_side=SELL resting=1 aggressor=4 qty=500000 price=1000000
EXPECT ORDER_BOOK_ACTION ts=4000 action=FILL qty=500000 price=1000000 side=BUY ord_id=1
EXPECT DEPTH_UPDATE ts=4000 action=UPDATE count=3 qty=5500000 price=1000000 side=BUY
EXPECT TRADE ts=4000 aggressor_side=SELL resting=2 aggressor=4 qty=1000000 price=1000000
EXPECT ORDER_BOOK_ACTION ts=4000 action=FILL qty=1000000 price=1000000 side=BUY ord_id=2
EXPECT DEPTH_UPDATE ts=4000 action=UPDATE count=3 qty=4500000 price=1000000 side=BUY
EXPECT TRADE ts=4000 aggressor_side=SELL resting=3 aggressor=4 qty=1500000 price=1000000
EXPECT ORDER_BOOK_ACTION ts=4000 action=FILL qty=1500000 price=1000000 side=BUY ord_id=3
EXPECT DEPTH_UPDATE ts=4000 action=UPDATE count=3 qty=3000000 price=1000000 side=BUY

ACTION NEW_ORDER ts=5000 cl_ord_id=5 account_id=2 side=SELL price=1000000 qty=1000000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=5000 cl_ord_id=5 ord_id=5
EXPECT ORDER_FILLED ts=5000 qty=166667 price=1000000 resting=1 aggressor=5
EXPECT ORDER_FILLED ts=5000 qty=333333 price=1000000 resting=2 aggressor=5
EXPECT ORDER_FILLED ts=5000 qty=500000 price=1000000 resting=3 aggressor=5
EXPECT TRADE ts=5000 aggressor_side=SELL resting=1 aggressor=5 qty=166667 price=1000000
EXPECT ORDER_BOOK_ACTION ts=5000 action=FILL qty=166667 price=1000000 side=BUY ord_id=1
EXPECT DEPTH_UPDATE ts=5000 action=UPDATE count=3 qty=2833333 price=1000000 side=BUY
EXPECT TRADE ts=5000 aggressor_side=SELL resting=2 aggressor=5 qty=333333 price=1000000
EXPECT ORDER_BOOK_ACTION ts=5000 action=FILL qty=333333 price=1000000 side=BUY ord_id=2
EXPECT DEPTH_UPDATE ts=5000 action=UPDATE count=3 qty=2500000 price=1000000 side=BUY
EXPECT TRADE ts=5000 aggressor_side=SELL resting=3 aggressor=5 qty=500000 price=1000000
EXPECT ORDER_BOOK_ACTION ts=5000 action=FILL qty=500000 price=1000000 side=BUY ord_id=3
EXPECT DEPTH_UPDATE ts=5000 action=UPDATE count=3 qty=2000000 price=1000000 side=BUY
