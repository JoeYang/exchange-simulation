        ["ice/*.journal"],
        allow_empty = True,
    ),
    visibility = ["//visibility:public"],
)

cc_test(
    name = "journal_test",
    srcs = ["journal_test.cc"],
    data = glob(["*.journal"]),
    deps = [
        "//test-harness:test_runner",
        "//test-harness:journal_parser",
        "@googletest//:gtest_main",
    ],
)

