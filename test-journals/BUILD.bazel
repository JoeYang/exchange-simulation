load("@rules_cc//cc:cc_binary.bzl", "cc_binary")
load("@rules_cc//cc:cc_test.bzl", "cc_test")

filegroup(
    name = "e2e_journals",
    srcs = glob(
        ["e2e/*.journal"],
        allow_empty = True,
    ),
    visibility = ["//visibility:public"],
)

