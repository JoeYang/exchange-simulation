# stress_deep_book.journal
# 50 buy orders across 50 bid levels and 50 sell orders across
# 50 ask levels (no crossing). Creates a 100-level-deep book at
# the FifoExchange limit. Tests maximum book depth.
CONFIG match_algo=FIFO tick_size=100 lot_size=10000 max_orders=1000 max_levels=100 max_order_ids=10000 price_band_low=0 price_band_high=0

ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=1 side=BUY price=1004900 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=1000 cl_ord_id=1 ord_id=1
EXPECT ORDER_BOOK_ACTION ts=1000 action=ADD qty=10000 price=1004900 side=BUY ord_id=1
EXPECT DEPTH_UPDATE ts=1000 action=ADD count=1 qty=10000 price=1004900 side=BUY
EXPECT TOP_OF_BOOK ts=1000 ask_qty=0 ask=0 bid_qty=10000 bid=1004900

ACTION NEW_ORDER ts=2000 cl_ord_id=2 account_id=1 side=BUY price=1004800 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=2000 cl_ord_id=2 ord_id=2
EXPECT ORDER_BOOK_ACTION ts=2000 action=ADD qty=10000 price=1004800 side=BUY ord_id=2
EXPECT DEPTH_UPDATE ts=2000 action=ADD count=1 qty=10000 price=1004800 side=BUY
EXPECT TOP_OF_BOOK ts=2000 ask_qty=0 ask=0 bid_qty=10000 bid=1004900

