# E2E: Iceberg order — only display_qty visible in MD
CONFIG match_algo=FIFO instrument=ES tick_size=2500 lot_size=10000

ACTION SESSION_START ts=0 state=CONTINUOUS

ACTION ILINK3_NEW_ORDER ts=1000 instrument=ES cl_ord_id=1 account=FIRM_A side=BUY price=50000000 qty=50000 type=LIMIT tif=DAY display_qty=10000
EXPECT EXEC_NEW cl_ord_id=1 status=NEW
EXPECT MD_BOOK_ADD side=BUY price=5000000000000 qty=1 num_orders=1
EXPECT MD_BOOK_UPDATE side=BUY price=5000000000000 qty=1 num_orders=2147483647
