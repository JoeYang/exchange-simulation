# economics_pro_rata_rounding.journal
# Verify pro-rata rounding edge cases.
# 3 equal orders of 10 lots, aggressor 10 lots.
# floor(100000*100000/300000) = 33333 each, sum = 99999.
# Remainder 1 goes to first order (FIFO).
# Final: 33334, 33333, 33333 = 100000. No quantity lost or created.
CONFIG match_algo=PRO_RATA tick_size=100 lot_size=10000 max_orders=1000 max_levels=100 max_order_ids=10000 price_band_low=0 price_band_high=0

ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=1 side=BUY price=1000000 qty=100000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=1000 cl_ord_id=1 ord_id=1
EXPECT ORDER_BOOK_ACTION ts=1000 action=ADD qty=100000 price=1000000 side=BUY ord_id=1
EXPECT DEPTH_UPDATE ts=1000 action=ADD count=1 qty=100000 price=1000000 side=BUY
EXPECT TOP_OF_BOOK ts=1000 ask_qty=0 ask=0 bid_qty=100000 bid=1000000

ACTION NEW_ORDER ts=2000 cl_ord_id=2 account_id=1 side=BUY price=1000000 qty=100000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=2000 cl_ord_id=2 ord_id=2
EXPECT ORDER_BOOK_ACTION ts=2000 action=ADD qty=100000 price=1000000 side=BUY ord_id=2
EXPECT DEPTH_UPDATE ts=2000 action=UPDATE count=2 qty=200000 price=1000000 side=BUY
EXPECT TOP_OF_BOOK ts=2000 ask_qty=0 ask=0 bid_qty=200000 bid=1000000

ACTION NEW_ORDER ts=3000 cl_ord_id=3 account_id=1 side=BUY price=1000000 qty=100000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=3000 cl_ord_id=3 ord_id=3
EXPECT ORDER_BOOK_ACTION ts=3000 action=ADD qty=100000 price=1000000 side=BUY ord_id=3
EXPECT DEPTH_UPDATE ts=3000 action=UPDATE count=3 qty=300000 price=1000000 side=BUY
EXPECT TOP_OF_BOOK ts=3000 ask_qty=0 ask=0 bid_qty=300000 bid=1000000

ACTION NEW_ORDER ts=4000 cl_ord_id=4 account_id=2 side=SELL price=1000000 qty=100000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=4000 cl_ord_id=4 ord_id=4
EXPECT ORDER_FILLED ts=4000 qty=33334 price=1000000 resting=1 aggressor=4
EXPECT ORDER_FILLED ts=4000 qty=33333 price=1000000 resting=2 aggressor=4
EXPECT ORDER_FILLED ts=4000 qty=33333 price=1000000 resting=3 aggressor=4
EXPECT TRADE ts=4000 aggressor_side=SELL resting=1 aggressor=4 qty=33334 price=1000000
EXPECT ORDER_BOOK_ACTION ts=4000 action=FILL qty=33334 price=1000000 side=BUY ord_id=1
EXPECT DEPTH_UPDATE ts=4000 action=UPDATE count=3 qty=266666 price=1000000 side=BUY
EXPECT TRADE ts=4000 aggressor_side=SELL resting=2 aggressor=4 qty=33333 price=1000000
EXPECT ORDER_BOOK_ACTION ts=4000 action=FILL qty=33333 price=1000000 side=BUY ord_id=2
EXPECT DEPTH_UPDATE ts=4000 action=UPDATE count=3 qty=233333 price=1000000 side=BUY
EXPECT TRADE ts=4000 aggressor_side=SELL resting=3 aggressor=4 qty=33333 price=1000000
EXPECT ORDER_BOOK_ACTION ts=4000 action=FILL qty=33333 price=1000000 side=BUY ord_id=3
EXPECT DEPTH_UPDATE ts=4000 action=UPDATE count=3 qty=200000 price=1000000 side=BUY
