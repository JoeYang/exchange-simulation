# pro_rata_equal_sizes.journal
# Three equal-sized orders at the same price. Pro-rata base allocation is
# equal for all; any remainder is distributed by FIFO (time priority).
#
# Setup:
#   o1 (cl_ord_id=1, buy 20000) -- oldest
#   o2 (cl_ord_id=2, buy 20000)
#   o3 (cl_ord_id=3, buy 20000)
#   Total resting = 60000
#
# Aggressor: sell 10000.
# Base allocation (floor):
#   o1: floor(20000 * 10000 / 60000) = 3333
#   o2: 3333
#   o3: 3333
#   Base total = 9999, remainder = 1
# Remainder: o1 gets +1 (oldest, FIFO). Final: o1=3334, o2=3333, o3=3333.
#
# Aggressor remaining: 10000->6666->3333->0. Last fill = FILLED.
# Bid price stays at 1005000 after fills -> NO TOP_OF_BOOK for action 3.
# Level totals: 60000-3334=56666, -3333=53333, -3333=50000.

CONFIG match_algo=PRO_RATA tick_size=100 lot_size=10000

# --- action 0: place first resting buy ---
ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=1 side=BUY price=1005000 qty=20000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ord_id=1 cl_ord_id=1 ts=1000
EXPECT ORDER_BOOK_ACTION ord_id=1 side=BUY price=1005000 qty=20000 action=ADD ts=1000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=20000 count=1 action=ADD ts=1000
EXPECT TOP_OF_BOOK bid=1005000 bid_qty=20000 ask=0 ask_qty=0 ts=1000

# --- action 1: place second resting buy ---
ACTION NEW_ORDER ts=2000 cl_ord_id=2 account_id=1 side=BUY price=1005000 qty=20000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ord_id=2 cl_ord_id=2 ts=2000
EXPECT ORDER_BOOK_ACTION ord_id=2 side=BUY price=1005000 qty=20000 action=ADD ts=2000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=40000 count=2 action=UPDATE ts=2000
EXPECT TOP_OF_BOOK bid=1005000 bid_qty=40000 ask=0 ask_qty=0 ts=2000

# --- action 2: place third resting buy ---
ACTION NEW_ORDER ts=3000 cl_ord_id=3 account_id=1 side=BUY price=1005000 qty=20000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ord_id=3 cl_ord_id=3 ts=3000
EXPECT ORDER_BOOK_ACTION ord_id=3 side=BUY price=1005000 qty=20000 action=ADD ts=3000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=60000 count=3 action=UPDATE ts=3000
EXPECT TOP_OF_BOOK bid=1005000 bid_qty=60000 ask=0 ask_qty=0 ts=3000

# --- action 3: aggressor sell fills equally, FIFO remainder to o1 ---
# No TOP_OF_BOOK: bid price unchanged after fills (orders still remain at 1005000).
ACTION NEW_ORDER ts=4000 cl_ord_id=4 account_id=2 side=SELL price=1005000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ord_id=4 cl_ord_id=4 ts=4000
EXPECT ORDER_FILLED aggressor=4 resting=1 price=1005000 qty=3334 ts=4000
EXPECT ORDER_FILLED aggressor=4 resting=2 price=1005000 qty=3333 ts=4000
EXPECT ORDER_FILLED aggressor=4 resting=3 price=1005000 qty=3333 ts=4000
EXPECT TRADE price=1005000 qty=3334 aggressor=4 resting=1 aggressor_side=SELL ts=4000
EXPECT ORDER_BOOK_ACTION ord_id=1 side=BUY price=1005000 qty=3334 action=FILL ts=4000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=56666 count=3 action=UPDATE ts=4000
EXPECT TRADE price=1005000 qty=3333 aggressor=4 resting=2 aggressor_side=SELL ts=4000
EXPECT ORDER_BOOK_ACTION ord_id=2 side=BUY price=1005000 qty=3333 action=FILL ts=4000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=53333 count=3 action=UPDATE ts=4000
EXPECT TRADE price=1005000 qty=3333 aggressor=4 resting=3 aggressor_side=SELL ts=4000
EXPECT ORDER_BOOK_ACTION ord_id=3 side=BUY price=1005000 qty=3333 action=FILL ts=4000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=50000 count=3 action=UPDATE ts=4000
