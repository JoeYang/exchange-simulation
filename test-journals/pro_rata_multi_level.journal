# pro_rata_multi_level.journal
# ProRata engine. Resting sells at two price levels.
# Level 1005000: ord1(30000) + ord2(20000) = 50000 total.
# Level 1006000: ord3(40000).
# Aggressor buy 90000 sweeps both levels.
# Level 1005000 consumed entirely (ProRata allocation),
# then level 1006000 consumed fully.
CONFIG match_algo=PRO_RATA tick_size=100 lot_size=10000 max_orders=1000 max_levels=100 max_order_ids=10000 price_band_low=0 price_band_high=0

ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=1 side=SELL price=1005000 qty=30000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=1000 cl_ord_id=1 ord_id=1
EXPECT ORDER_BOOK_ACTION ts=1000 action=ADD qty=30000 price=1005000 side=SELL ord_id=1
EXPECT DEPTH_UPDATE ts=1000 action=ADD count=1 qty=30000 price=1005000 side=SELL
EXPECT TOP_OF_BOOK ts=1000 ask_qty=30000 ask=1005000 bid_qty=0 bid=0

ACTION NEW_ORDER ts=2000 cl_ord_id=2 account_id=1 side=SELL price=1005000 qty=20000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=2000 cl_ord_id=2 ord_id=2
EXPECT ORDER_BOOK_ACTION ts=2000 action=ADD qty=20000 price=1005000 side=SELL ord_id=2
EXPECT DEPTH_UPDATE ts=2000 action=UPDATE count=2 qty=50000 price=1005000 side=SELL
EXPECT TOP_OF_BOOK ts=2000 ask_qty=50000 ask=1005000 bid_qty=0 bid=0

ACTION NEW_ORDER ts=3000 cl_ord_id=3 account_id=1 side=SELL price=1006000 qty=40000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=3000 cl_ord_id=3 ord_id=3
EXPECT ORDER_BOOK_ACTION ts=3000 action=ADD qty=40000 price=1006000 side=SELL ord_id=3
EXPECT DEPTH_UPDATE ts=3000 action=ADD count=1 qty=40000 price=1006000 side=SELL
EXPECT TOP_OF_BOOK ts=3000 ask_qty=50000 ask=1005000 bid_qty=0 bid=0

ACTION NEW_ORDER ts=4000 cl_ord_id=4 account_id=2 side=BUY price=1006000 qty=90000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=4000 cl_ord_id=4 ord_id=4
EXPECT ORDER_PARTIALLY_FILLED resting_rem=0 ts=4000 aggressor_rem=40000 qty=30000 price=1005000 resting=1 aggressor=4
EXPECT ORDER_PARTIALLY_FILLED resting_rem=0 ts=4000 aggressor_rem=40000 qty=20000 price=1005000 resting=2 aggressor=4
EXPECT ORDER_FILLED ts=4000 qty=40000 price=1006000 resting=3 aggressor=4
EXPECT TRADE ts=4000 aggressor_side=BUY resting=1 aggressor=4 qty=30000 price=1005000
EXPECT ORDER_BOOK_ACTION ts=4000 action=FILL qty=30000 price=1005000 side=SELL ord_id=1
EXPECT DEPTH_UPDATE ts=4000 action=REMOVE count=0 qty=0 price=1005000 side=SELL
EXPECT TRADE ts=4000 aggressor_side=BUY resting=2 aggressor=4 qty=20000 price=1005000
EXPECT ORDER_BOOK_ACTION ts=4000 action=FILL qty=20000 price=1005000 side=SELL ord_id=2
EXPECT DEPTH_UPDATE ts=4000 action=REMOVE count=0 qty=0 price=1005000 side=SELL
EXPECT TRADE ts=4000 aggressor_side=BUY resting=3 aggressor=4 qty=40000 price=1006000
EXPECT ORDER_BOOK_ACTION ts=4000 action=FILL qty=40000 price=1006000 side=SELL ord_id=3
EXPECT DEPTH_UPDATE ts=4000 action=REMOVE count=0 qty=0 price=1006000 side=SELL
EXPECT TOP_OF_BOOK ts=4000 ask_qty=0 ask=0 bid_qty=0 bid=0
