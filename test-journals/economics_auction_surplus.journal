# economics_auction_surplus.journal
# Verify auction surplus is correct.
# Buy 100 lots @ 101.0000, Sell 50 lots @ 99.0000.
# Auction fills 50 lots (min of buy/sell).
# Buy surplus: 50 lots remain in book and are fillable in continuous.
CONFIG match_algo=FIFO tick_size=100 lot_size=10000 max_orders=1000 max_levels=100 max_order_ids=10000 price_band_low=0 price_band_high=0

ACTION SET_SESSION_STATE ts=1000 state=PRE_OPEN
EXPECT MARKET_STATUS ts=1000 state=PRE_OPEN

ACTION NEW_ORDER ts=2000 cl_ord_id=1 account_id=1 side=BUY price=1010000 qty=1000000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=2000 cl_ord_id=1 ord_id=1
EXPECT ORDER_BOOK_ACTION ts=2000 action=ADD qty=1000000 price=1010000 side=BUY ord_id=1
EXPECT DEPTH_UPDATE ts=2000 action=ADD count=1 qty=1000000 price=1010000 side=BUY
EXPECT TOP_OF_BOOK ts=2000 ask_qty=0 ask=0 bid_qty=1000000 bid=1010000

ACTION NEW_ORDER ts=3000 cl_ord_id=2 account_id=2 side=SELL price=990000 qty=500000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=3000 cl_ord_id=2 ord_id=2
EXPECT ORDER_BOOK_ACTION ts=3000 action=ADD qty=500000 price=990000 side=SELL ord_id=2
EXPECT DEPTH_UPDATE ts=3000 action=ADD count=1 qty=500000 price=990000 side=SELL
EXPECT TOP_OF_BOOK ts=3000 ask_qty=500000 ask=990000 bid_qty=1000000 bid=1010000

ACTION PUBLISH_INDICATIVE ts=4000 reference_price=1000000
EXPECT INDICATIVE_PRICE ts=4000 sell_surplus=0 buy_surplus=500000 matched_vol=500000 price=1010000

ACTION EXECUTE_AUCTION ts=5000 reference_price=1000000
EXPECT ORDER_PARTIALLY_FILLED resting_rem=0 ts=5000 aggressor_rem=500000 qty=500000 price=1010000 resting=2 aggressor=1
EXPECT TRADE ts=5000 aggressor_side=BUY resting=2 aggressor=1 qty=500000 price=1010000
EXPECT ORDER_BOOK_ACTION ts=5000 action=FILL qty=500000 price=1010000 side=BUY ord_id=1
EXPECT ORDER_BOOK_ACTION ts=5000 action=FILL qty=500000 price=1010000 side=SELL ord_id=2
EXPECT DEPTH_UPDATE ts=5000 action=REMOVE count=0 qty=0 price=990000 side=SELL
EXPECT TOP_OF_BOOK ts=5000 ask_qty=0 ask=0 bid_qty=500000 bid=1010000

ACTION SET_SESSION_STATE ts=6000 state=CONTINUOUS
EXPECT MARKET_STATUS ts=6000 state=CONTINUOUS

ACTION NEW_ORDER ts=7000 cl_ord_id=3 account_id=2 side=SELL price=1010000 qty=500000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ts=7000 cl_ord_id=3 ord_id=3
EXPECT ORDER_FILLED ts=7000 qty=500000 price=1010000 resting=1 aggressor=3
EXPECT TRADE ts=7000 aggressor_side=SELL resting=1 aggressor=3 qty=500000 price=1010000
EXPECT ORDER_BOOK_ACTION ts=7000 action=FILL qty=500000 price=1010000 side=BUY ord_id=1
EXPECT DEPTH_UPDATE ts=7000 action=REMOVE count=0 qty=0 price=1010000 side=BUY
EXPECT TOP_OF_BOOK ts=7000 ask_qty=0 ask=0 bid_qty=0 bid=0
