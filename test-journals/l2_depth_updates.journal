# L2 (DepthUpdate) verification: confirm ADD, UPDATE, and REMOVE actions.
# ADD fires when the first order arrives at a new price level.
# UPDATE fires when additional orders join an existing level (qty and count increase).
# UPDATE also fires when an order is cancelled from a level that still has orders.
# REMOVE fires when the last order at a level is cancelled or filled.
CONFIG match_algo=FIFO tick_size=100 lot_size=10000

# First buy at 1005000 — new level: DepthUpdate ADD
ACTION NEW_ORDER ts=1000 cl_ord_id=1 account_id=1 side=BUY price=1005000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ord_id=1 cl_ord_id=1 ts=1000
EXPECT ORDER_BOOK_ACTION ord_id=1 side=BUY price=1005000 qty=10000 action=ADD ts=1000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=10000 count=1 action=ADD ts=1000
EXPECT TOP_OF_BOOK bid=1005000 bid_qty=10000 ask=0 ask_qty=0 ts=1000

# Second buy at same price — existing level: DepthUpdate UPDATE (qty=20000, count=2)
ACTION NEW_ORDER ts=2000 cl_ord_id=2 account_id=1 side=BUY price=1005000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ord_id=2 cl_ord_id=2 ts=2000
EXPECT ORDER_BOOK_ACTION ord_id=2 side=BUY price=1005000 qty=10000 action=ADD ts=2000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=20000 count=2 action=UPDATE ts=2000
EXPECT TOP_OF_BOOK bid=1005000 bid_qty=20000 ask=0 ask_qty=0 ts=2000

# Third buy at same price — DepthUpdate UPDATE (qty=30000, count=3)
ACTION NEW_ORDER ts=3000 cl_ord_id=3 account_id=1 side=BUY price=1005000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ord_id=3 cl_ord_id=3 ts=3000
EXPECT ORDER_BOOK_ACTION ord_id=3 side=BUY price=1005000 qty=10000 action=ADD ts=3000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=30000 count=3 action=UPDATE ts=3000
EXPECT TOP_OF_BOOK bid=1005000 bid_qty=30000 ask=0 ask_qty=0 ts=3000

# Cancel middle order — level still has 2 orders: DepthUpdate UPDATE (qty=20000, count=2)
ACTION CANCEL ts=4000 ord_id=2
EXPECT ORDER_CANCELLED ord_id=2 ts=4000 reason=USER_REQUESTED
EXPECT ORDER_BOOK_ACTION ord_id=2 side=BUY price=1005000 qty=10000 action=CANCEL ts=4000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=20000 count=2 action=UPDATE ts=4000

# Cancel ord_id=1 — level still has 1 order (ord_id=3): DepthUpdate UPDATE (qty=10000, count=1)
ACTION CANCEL ts=5000 ord_id=1
EXPECT ORDER_CANCELLED ord_id=1 ts=5000 reason=USER_REQUESTED
EXPECT ORDER_BOOK_ACTION ord_id=1 side=BUY price=1005000 qty=10000 action=CANCEL ts=5000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=10000 count=1 action=UPDATE ts=5000

# Add a resting sell to test fill-driven REMOVE
ACTION NEW_ORDER ts=6000 cl_ord_id=4 account_id=2 side=SELL price=1005000 qty=10000 type=LIMIT tif=GTC
EXPECT ORDER_ACCEPTED ord_id=4 cl_ord_id=4 ts=6000
EXPECT ORDER_FILLED aggressor=4 resting=3 price=1005000 qty=10000 ts=6000
EXPECT TRADE price=1005000 qty=10000 aggressor=4 resting=3 aggressor_side=SELL ts=6000
EXPECT ORDER_BOOK_ACTION ord_id=3 side=BUY price=1005000 qty=10000 action=FILL ts=6000
EXPECT DEPTH_UPDATE side=BUY price=1005000 qty=0 count=0 action=REMOVE ts=6000
EXPECT TOP_OF_BOOK bid=0 bid_qty=0 ask=0 ask_qty=0 ts=6000
